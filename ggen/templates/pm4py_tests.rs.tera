{% set py_name    = row["?pyName"]        | default(value="unknown") %}
{% set call_style = row["?callStyle"]     | default(value="log_only") %}
{% set convert    = row["?convertResult"] | default(value="unit") %}
{% set module     = row["?module"]        | default(value="discovery") %}

#[test]
fn {{ fn_name }}_official() {
    if !pm4py_available() {
        eprintln!("SKIP {{ fn_name }}_official: pm4py not available");
        return;
    }
{%- if call_style == "log_and_net" %}
    let log = two_activity_log();
    let net = ab_petri_net();
    let result = pyo3::Python::with_gil(|py| {
        pm4py::python::generated::{{ module }}::{{ fn_name }}(py, &log, &net)
    });
{%- elif call_style == "log_and_model" %}
    let log = two_activity_log();
    let result = pyo3::Python::with_gil(|py| {
        pm4py::python::generated::{{ module }}::{{ fn_name }}(py, &log)
    });
{%- elif call_style == "io_write" %}
{%- if py_name is containing("ocel") %}
    // SKIP: OCEL write functions require an OCEL object, not an EventLog
    return;
    #[allow(unreachable_code)]
    let result: Result<(), ()> = Ok(());
{%- else %}
    let log = two_activity_log();
    let tmp = tempfile::NamedTempFile::new().expect("tmp file must be created");
    let path = tmp.path().to_str().expect("path must be valid UTF-8");
    let result = pyo3::Python::with_gil(|py| {
        pm4py::python::generated::{{ module }}::{{ fn_name }}(py, &log, path)
    });
{%- endif %}
{%- elif call_style == "io_read" %}
{%- if py_name is containing("pnml") %}
    let result = pyo3::Python::with_gil(|py| {
        pm4py::python::generated::{{ module }}::{{ fn_name }}(py, PNML_PATH)
    });
{%- elif py_name is containing("ptml") %}
    let result = pyo3::Python::with_gil(|py| {
        pm4py::python::generated::{{ module }}::{{ fn_name }}(py, PTML_PATH)
    });
{%- elif py_name is containing("bpmn") %}
    let result = pyo3::Python::with_gil(|py| {
        pm4py::python::generated::{{ module }}::{{ fn_name }}(py, BPMN_PATH)
    });
{%- elif py_name is containing("dfg") %}
    let result = pyo3::Python::with_gil(|py| {
        pm4py::python::generated::{{ module }}::{{ fn_name }}(py, DFG_PATH)
    });
{%- elif py_name is containing("ocel") %}
    // SKIP: no OCEL test fixture available
    return;
    #[allow(unreachable_code)]
    let result: Result<(), ()> = Ok(());
{%- else %}
    let result = pyo3::Python::with_gil(|py| {
        pm4py::python::generated::{{ module }}::{{ fn_name }}(py, XES_PATH)
    });
{%- endif %}
{%- else %}
    let log = two_activity_log();
    let result = pyo3::Python::with_gil(|py| {
        pm4py::python::generated::{{ module }}::{{ fn_name }}(py, &log)
    });
{%- endif %}
{%- if convert == "petri_net_triple" %}
    let discovered = result.expect("{{ py_name }} failed");
    assert!(!discovered.places.is_empty(),
        "{{ py_name }}: PetriNet must have places");
    assert!(!discovered.transitions.is_empty(),
        "{{ py_name }}: PetriNet must have transitions");
{%- elif convert == "f64" or convert == "fitness_dict" %}
    let score = result.expect("{{ py_name }} failed");
    assert!(score >= 0.0,
        "{{ py_name }}: score must be non-negative, got {score}");
{%- elif convert == "dict" %}
    result.expect("{{ py_name }} failed");
{%- elif convert == "list_dict" %}
    let avg = result.expect("{{ py_name }} failed");
    assert!((0.0..=1.0).contains(&avg),
        "{{ py_name }}: avg must be in [0,1], got {avg}");
{%- elif convert == "event_log" %}
    result.expect("{{ py_name }} read failed");
{%- elif convert == "string" %}
    let s = result.expect("{{ py_name }} failed");
    let _ = s;
{%- else %}
    result.expect("{{ py_name }} failed");
{%- endif %}
}
