  </trace>
</log>"#;

        fs::write(&log_path, xes_content).expect("Failed to write SBP4 log");
        log_path
    }

    #[test]
    fn sbp4_state_history_log_creation() {
        let log_path = create_state_history_log();
        assert!(
            Path::new(&log_path).exists(),
            "SBP4 log file should be created"
        );
        assert!(
            log_path.ends_with("state_history_sbp4.xes"),
            "Should use correct filename"
        );

        let content = fs::read_to_string(&log_path).expect("Should read log");
        assert!(
            content.contains("enter_level_1"),
            "Should have level 1 entry events"
        );
        assert!(
            content.contains("escalate_to_level_2"),
            "Should have escalation events"
        );
        assert!(
            content.matches("<trace>").count() == 4,
            "Should have exactly 4 traces"
        );
    }

    #[test]
    fn sbp4_state_history_escalation_paths() {
        let log_path = create_state_history_log();
        let content = fs::read_to_string(&log_path).expect("Should read log");

        // Verify escalation path elements exist
        assert!(
            content.contains("escalate_to_level_2"),
            "Should have level 2 escalations"
        );
        assert!(
            content.contains("escalate_to_level_3"),
            "Should have level 3 escalations"
        );
        assert!(
            content.contains("escalate_to_external"),
            "Should have external escalations"
        );
        assert!(
            content.contains("enter_level_1"),
            "Should have level 1 entry"
        );
        assert!(
            content.contains("enter_level_2"),
            "Should have level 2 entry"
        );
        assert!(
            content.contains("enter_level_3"),
            "Should have level 3 entry"
        );

        // Verify level progression
        let traces: Vec<&str> = content.split("<trace>").collect();
        let mut has_escalation_pattern = false;
        for trace in &traces[1..] {
            if trace.contains("escalate_to_level_2") && trace.contains("enter_level_2") {
                has_escalation_pattern = true;
                break;
            }
        }
        assert!(
            has_escalation_pattern,
            "Should have at least one escalation path"
        );
    }

    #[test]
    fn sbp4_state_history_sequencing() {
        let log_path = create_state_history_log();
        let content = fs::read_to_string(&log_path).expect("Should read log");

        let traces: Vec<&str> = content.split("<trace>").collect();
        for (idx, trace) in traces[1..].iter().enumerate() {
            // Each trace should start with enter_level_1
            assert!(
                trace.contains("enter_level_1"),
                "Trace {} should start at level 1",
                idx + 1
            );

            // If escalate_to_level_2 exists, enter_level_2 should follow
            if trace.contains("escalate_to_level_2") {
                let escalate_pos = trace.find("escalate_to_level_2").unwrap();
                let enter_pos = trace.find("enter_level_2").unwrap_or(0);
                assert!(
                    enter_pos > escalate_pos,
                    "enter_level_2 should follow escalate_to_level_2"
                );
            }

            // If escalate_to_level_3 exists, enter_level_3 should follow
            if trace.contains("escalate_to_level_3") {
                let escalate_pos = trace.find("escalate_to_level_3").unwrap();
                let enter_pos = trace.find("enter_level_3").unwrap_or(0);
                assert!(
                    enter_pos > escalate_pos,
                    "enter_level_3 should follow escalate_to_level_3"
                );
            }
        }
    }

