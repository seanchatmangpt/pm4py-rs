    // ═══════════════════════════════════════════════════════════════════════════════
    // SBP5: CONCURRENT STATE MACHINES — Multiple independent state machines
    // ═══════════════════════════════════════════════════════════════════════════════
    //
    // Pattern: Multiple parallel state machines (e.g., order + shipping simultaneously)
    // States Machine 1: [submitted, processing, ready_to_ship]
    // States Machine 2: [payment_pending, paid, refunded]
    // Synchronization: Both must complete before closure
    //
    // Structure:
    // - Split into parallel regions (each with own state machine)
    // - Independent state progressions
    // - Join when all machines complete
    // - Marking shows state of all machines
    //
    // Real-world: Order fulfillment with parallel processes
    // - Order processing (verify items) in parallel with
    // - Payment processing (charge card)
    // - Both must complete before shipping
    // - XOR join ensures both paths merged before continue
    //
    // Traces (3 total):
    // - Trace 1: Both processes succeed in parallel
    // - Trace 2: Payment completes before items ready
    // - Trace 3: Items ready before payment completes (timing varies)
    // All traces show same activity sequence but different timing

    fn create_concurrent_state_machines_log() -> String {
        let test_data_dir = get_test_data_dir();
        ensure_test_data_dir();

        let log_path = format!("{}/concurrent_state_machines_sbp5.xes", test_data_dir);

        let xes_content = r#"<?xml version="1.0" encoding="UTF-8"?>
<log xes.version="1.0" xes.features="nested-attributes" xmlns="http://www.xes-standard.org/">
  <extension name="Concept" prefix="concept" uri="http://www.xes-standard.org/concept.xesext"/>
  <extension name="Time" prefix="time" uri="http://www.xes-standard.org/time.xesext"/>
  <extension name="Org" prefix="org" uri="http://www.xes-standard.org/org.xesext"/>
  <global scope="trace">
    <string key="concept:name" value="case name"/>
  </global>
  <global scope="event">
    <string key="concept:name" value="activity name"/>
    <date key="time:timestamp" value="timestamp"/>
    <string key="org:role" value="role"/>
  </global>
  <!-- Trace 1: Payment completes before items ready (payment path faster) -->
  <trace>
    <string key="concept:name" value="order_001"/>
    <event>
      <string key="concept:name" value="receive_order"/>
      <date key="time:timestamp" value="2024-01-01T10:00:00.000Z"/>
      <string key="org:role" value="order_mgmt"/>
    </event>
    <!-- Order processing starts -->
    <event>
      <string key="concept:name" value="verify_items"/>
      <date key="time:timestamp" value="2024-01-01T10:05:00.000Z"/>
      <string key="org:role" value="warehouse"/>
    </event>
    <!-- Payment processing starts in parallel -->
    <event>
      <string key="concept:name" value="process_payment"/>
      <date key="time:timestamp" value="2024-01-01T10:05:00.000Z"/>
      <string key="org:role" value="payment_system"/>
    </event>
    <!-- Payment completes first -->
    <event>
      <string key="concept:name" value="payment_confirmed"/>
      <date key="time:timestamp" value="2024-01-01T10:06:00.000Z"/>
      <string key="org:role" value="payment_system"/>
    </event>
    <!-- Order processing continues -->
    <event>
      <string key="concept:name" value="pick_items"/>
      <date key="time:timestamp" value="2024-01-01T10:15:00.000Z"/>
      <string key="org:role" value="warehouse"/>
    </event>
    <event>
      <string key="concept:name" value="pack_order"/>
      <date key="time:timestamp" value="2024-01-01T10:30:00.000Z"/>
      <string key="org:role" value="warehouse"/>
    </event>
    <!-- Both paths complete -->
    <event>
      <string key="concept:name" value="ready_to_ship"/>
      <date key="time:timestamp" value="2024-01-01T10:45:00.000Z"/>
      <string key="org:role" value="warehouse"/>
    </event>
    <event>
      <string key="concept:name" value="create_shipment"/>
      <date key="time:timestamp" value="2024-01-01T11:00:00.000Z"/>
      <string key="org:role" value="shipping"/>
    </event>
  </trace>
  <!-- Trace 2: Items ready before payment completes (order path faster) -->
  <trace>
    <string key="concept:name" value="order_002"/>
    <event>
      <string key="concept:name" value="receive_order"/>
      <date key="time:timestamp" value="2024-01-02T10:00:00.000Z"/>
      <string key="org:role" value="order_mgmt"/>
    </event>
    <!-- Both processes start in parallel -->
    <event>
      <string key="concept:name" value="verify_items"/>
      <date key="time:timestamp" value="2024-01-02T10:05:00.000Z"/>
      <string key="org:role" value="warehouse"/>
    </event>
    <event>
      <string key="concept:name" value="process_payment"/>
      <date key="time:timestamp" value="2024-01-02T10:05:00.000Z"/>
      <string key="org:role" value="payment_system"/>
    </event>
    <!-- Order processing completes first -->
    <event>
      <string key="concept:name" value="pick_items"/>
      <date key="time:timestamp" value="2024-01-02T10:10:00.000Z"/>
      <string key="org:role" value="warehouse"/>
    </event>
    <event>
      <string key="concept:name" value="pack_order"/>
      <date key="time:timestamp" value="2024-01-02T10:20:00.000Z"/>
      <string key="org:role" value="warehouse"/>
    </event>
    <!-- Payment still processing -->
    <event>
      <string key="concept:name" value="payment_confirmed"/>
      <date key="time:timestamp" value="2024-01-02T10:30:00.000Z"/>
      <string key="org:role" value="payment_system"/>
    </event>
    <!-- Both paths complete, shipment can proceed -->
    <event>
      <string key="concept:name" value="ready_to_ship"/>
      <date key="time:timestamp" value="2024-01-02T10:45:00.000Z"/>
      <string key="org:role" value="warehouse"/>
    </event>
    <event>
      <string key="concept:name" value="create_shipment"/>
      <date key="time:timestamp" value="2024-01-02T11:00:00.000Z"/>
      <string key="org:role" value="shipping"/>
    </event>
  </trace>
  <!-- Trace 3: Both processes complete at similar time -->
  <trace>
    <string key="concept:name" value="order_003"/>
    <event>
      <string key="concept:name" value="receive_order"/>
      <date key="time:timestamp" value="2024-01-03T10:00:00.000Z"/>
      <string key="org:role" value="order_mgmt"/>
    </event>
    <!-- Both processes start in parallel -->
    <event>
      <string key="concept:name" value="verify_items"/>
      <date key="time:timestamp" value="2024-01-03T10:05:00.000Z"/>
      <string key="org:role" value="warehouse"/>
    </event>
    <event>
      <string key="concept:name" value="process_payment"/>
      <date key="time:timestamp" value="2024-01-03T10:05:00.000Z"/>
      <string key="org:role" value="payment_system"/>
    </event>
    <!-- Order path continues -->
    <event>
      <string key="concept:name" value="pick_items"/>
      <date key="time:timestamp" value="2024-01-03T10:12:00.000Z"/>
      <string key="org:role" value="warehouse"/>
    </event>
    <!-- Payment completes in middle -->
    <event>
      <string key="concept:name" value="payment_confirmed"/>
      <date key="time:timestamp" value="2024-01-03T10:20:00.000Z"/>
      <string key="org:role" value="payment_system"/>
    </event>
    <!-- Order path continues -->
    <event>
      <string key="concept:name" value="pack_order"/>
      <date key="time:timestamp" value="2024-01-03T10:25:00.000Z"/>
      <string key="org:role" value="warehouse"/>
    </event>
    <!-- Both paths complete -->
    <event>
      <string key="concept:name" value="ready_to_ship"/>
      <date key="time:timestamp" value="2024-01-03T10:45:00.000Z"/>
      <string key="org:role" value="warehouse"/>
    </event>
    <event>
      <string key="concept:name" value="create_shipment"/>
      <date key="time:timestamp" value="2024-01-03T11:00:00.000Z"/>
      <string key="org:role" value="shipping"/>
    </event>
  </trace>
</log>"#;

        fs::write(&log_path, xes_content).expect("Failed to write SBP5 log");
        log_path
    }

    #[test]
    fn sbp5_concurrent_state_machines_log_creation() {
        let test_data_dir = get_test_data_dir();
        ensure_test_data_dir();

        // Create a fresh log for this test
        let log_path = format!("{}/concurrent_test.xes", test_data_dir);
        let xes_content = r#"<?xml version="1.0" encoding="UTF-8"?>
<log xes.version="1.0" xes.features="nested-attributes" xmlns="http://www.xes-standard.org/">
  <extension name="Concept" prefix="concept" uri="http://www.xes-standard.org/concept.xesext"/>
  <extension name="Time" prefix="time" uri="http://www.xes-standard.org/time.xesext"/>
  <global scope="trace">
    <string key="concept:name" value="case name"/>
  </global>
  <global scope="event">
    <string key="concept:name" value="activity name"/>
    <date key="time:timestamp" value="timestamp"/>
  </global>
  <trace>
    <string key="concept:name" value="order_001"/>
    <event>
      <string key="concept:name" value="verify_items"/>
      <date key="time:timestamp" value="2024-01-01T10:05:00.000Z"/>
    </event>
    <event>
      <string key="concept:name" value="process_payment"/>
      <date key="time:timestamp" value="2024-01-01T10:05:00.000Z"/>
    </event>
    <event>
      <string key="concept:name" value="ready_to_ship"/>
      <date key="time:timestamp" value="2024-01-01T10:45:00.000Z"/>
    </event>
  </trace>
</log>"#;

        fs::write(&log_path, xes_content).expect("Failed to write concurrent test log");
        let content = fs::read_to_string(&log_path).expect("Should read log");

        assert!(
            content.contains("verify_items"),
            "Should have order processing events"
        );
        assert!(
            content.contains("process_payment"),
            "Should have payment events"
        );
        assert!(
            content.contains("ready_to_ship"),
            "Should have synchronization point"
        );
    }

    #[test]
    fn sbp5_concurrent_state_machines_parallelism() {
        let log_path = create_concurrent_state_machines_log();
        let content = fs::read_to_string(&log_path).expect("Should read log");

        let traces: Vec<&str> = content.split("<trace>").collect();
        for trace in &traces[1..] {
            // Both payment and order processing should appear in each trace
            assert!(
                trace.contains("process_payment"),
                "Should have payment processing"
            );
            assert!(
                trace.contains("verify_items"),
                "Should have order processing"
            );

            // Both should complete before ready_to_ship
            let payment_idx = trace.find("payment_confirmed").unwrap_or(0);
            let ready_idx = trace.find("ready_to_ship").unwrap_or(0);
            assert!(
                payment_idx > 0 && ready_idx > payment_idx,
                "Payment must complete before ready_to_ship"
            );

            let verify_idx = trace.find("verify_items").unwrap_or(0);
            assert!(
                verify_idx > 0 && ready_idx > verify_idx,
                "Verify items must complete before ready_to_ship"
            );
        }
    }

    #[test]
    fn sbp5_concurrent_state_machines_interleaving() {
        let log_path = create_concurrent_state_machines_log();
        let content = fs::read_to_string(&log_path).expect("Should read log");

        let traces: Vec<&str> = content.split("<trace>").collect();

        // Trace 1: Payment finishes first
        // Trace 2: Order finishes first
        // Trace 3: Interleaved (payment in middle of order)

        for (idx, trace) in traces[1..].iter().enumerate() {
            if idx == 0 {
                // Trace 1: payment_confirmed before pack_order
                let payment_pos = trace.find("payment_confirmed").unwrap_or(0);
                let pack_pos = trace.find("pack_order").unwrap_or(0);
                assert!(
                    payment_pos > 0 && pack_pos > payment_pos,
                    "Trace 1: Payment should finish before pack"
                );
            } else if idx == 1 {
                // Trace 2: pack_order before payment_confirmed
                let pack_pos = trace.find("pack_order").unwrap_or(0);
                let payment_pos = trace.find("payment_confirmed").unwrap_or(0);
                assert!(
                    pack_pos > 0 && payment_pos > pack_pos,
                    "Trace 2: Pack should finish before payment"
                );
            } else {
                // Trace 3: payment_confirmed between pick and pack (interleaved)
                let pick_pos = trace.find("pick_items").unwrap_or(0);
                let payment_pos = trace.find("payment_confirmed").unwrap_or(0);
                let pack_pos = trace.find("pack_order").unwrap_or(0);
                assert!(
                    pick_pos > 0 && payment_pos > pick_pos && pack_pos > payment_pos,
                    "Trace 3: Should be interleaved"
                );
            }
        }
    }

