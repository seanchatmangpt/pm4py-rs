    </event>
    <event>
      <string key="concept:name" value="escalate_to_level_2"/>
      <date key="time:timestamp" value="2024-01-04T09:00:00.000Z"/>
      <string key="org:resource" value="support_l1_b"/>
    </event>
    <event>
      <string key="concept:name" value="enter_level_2"/>
      <date key="time:timestamp" value="2024-01-04T09:15:00.000Z"/>
      <string key="org:resource" value="support_l2_a"/>
    </event>
    <event>
      <string key="concept:name" value="handle_ticket"/>
      <date key="time:timestamp" value="2024-01-04T10:00:00.000Z"/>
      <string key="org:resource" value="support_l2_a"/>
    </event>
    <event>
      <string key="concept:name" value="escalate_to_level_3"/>
      <date key="time:timestamp" value="2024-01-04T11:00:00.000Z"/>
      <string key="org:resource" value="support_l2_a"/>
    </event>
    <event>
      <string key="concept:name" value="enter_level_3"/>
      <date key="time:timestamp" value="2024-01-04T11:30:00.000Z"/>
      <string key="org:resource" value="support_l3_b"/>
