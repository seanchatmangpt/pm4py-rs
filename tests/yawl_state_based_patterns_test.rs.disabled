    // ═══════════════════════════════════════════════════════════════════════════════
    // SBP3: GUARD CONDITIONS — Transitions enabled by state predicates
    // ═══════════════════════════════════════════════════════════════════════════════
    //
    // Pattern: Transitions guarded by predicates on state/data
    // States: [initial, validate, (approved if credit_ok), (rejected if credit_fail)]
    // Guards: transition to approval ONLY if credit_score > threshold
    //         transition to rejection ONLY if credit_score <= threshold
    //
    // Structure:
    // - Same activity (validate) leads to different next states based on guard
    // - Guards are implicit in the log (can infer from consistent patterns)
    // - No explicit decision event; the validation result determines path
    //
    // Real-world: Credit scoring in loan process
    // - Credit check → (branch based on score)
    // - High credit → approved path
    // - Low credit → review/reject path
    // - Guard prevents "impossible" transitions
    //
    // Traces (6 total):
    // - 3 cases with high credit: validate → approved
    // - 3 cases with low credit: validate → request_more_info (guard prevents direct approval)

    fn create_guard_conditions_log() -> String {
        let test_data_dir = get_test_data_dir();
        ensure_test_data_dir();

        let log_path = format!("{}/guard_conditions_sbp3.xes", test_data_dir);

        let xes_content = r#"<?xml version="1.0" encoding="UTF-8"?>
<log xes.version="1.0" xes.features="nested-attributes" xmlns="http://www.xes-standard.org/">
  <extension name="Concept" prefix="concept" uri="http://www.xes-standard.org/concept.xesext"/>
  <extension name="Time" prefix="time" uri="http://www.xes-standard.org/time.xesext"/>
  <extension name="Org" prefix="org" uri="http://www.xes-standard.org/org.xesext"/>
  <global scope="trace">
    <string key="concept:name" value="case name"/>
    <int key="credit:score" value="score"/>
  </global>
  <global scope="event">
    <string key="concept:name" value="activity name"/>
    <date key="time:timestamp" value="timestamp"/>
    <string key="org:role" value="role"/>
  </global>
  <!-- High Credit Cases (score >= 700): validation → approved -->
  <trace>
    <string key="concept:name" value="app_001"/>
    <int key="credit:score" value="750"/>
    <event>
      <string key="concept:name" value="submit_application"/>
