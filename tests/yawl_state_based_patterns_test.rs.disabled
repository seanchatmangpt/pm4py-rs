    </event>
  </trace>
  <!-- Trace 4: Three escalations (L1 → L2 → L3 → external) -->
  <trace>
    <string key="concept:name" value="ticket_004"/>
    <event>
      <string key="concept:name" value="enter_level_1"/>
      <date key="time:timestamp" value="2024-01-04T08:00:00.000Z"/>
