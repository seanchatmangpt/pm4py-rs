    #[test]
    fn sbp1_state_machine_log_creation() {
        // Create log with fresh write
        let test_data_dir = get_test_data_dir();
        ensure_test_data_dir();
        let log_path = format!("{}/state_machine_sbp1_test.xes", test_data_dir);

        let xes_content = r#"<?xml version="1.0" encoding="UTF-8"?>
<log xes.version="1.0" xes.features="nested-attributes" xmlns="http://www.xes-standard.org/">
  <extension name="Concept" prefix="concept" uri="http://www.xes-standard.org/concept.xesext"/>
  <extension name="Time" prefix="time" uri="http://www.xes-standard.org/time.xesext"/>
  <global scope="trace">
    <string key="concept:name" value="case name"/>
  </global>
  <global scope="event">
    <string key="concept:name" value="activity name"/>
    <date key="time:timestamp" value="timestamp"/>
  </global>
  <trace>
    <string key="concept:name" value="loan_001"/>
    <event>
      <string key="concept:name" value="enter_submitted"/>
      <date key="time:timestamp" value="2024-01-01T10:00:00.000Z"/>
    </event>
    <event>
      <string key="concept:name" value="enter_under_review"/>
      <date key="time:timestamp" value="2024-01-01T10:10:00.000Z"/>
    </event>
    <event>
      <string key="concept:name" value="enter_approved"/>
      <date key="time:timestamp" value="2024-01-01T10:30:00.000Z"/>
    </event>
    <event>
      <string key="concept:name" value="enter_closed"/>
      <date key="time:timestamp" value="2024-01-01T10:45:00.000Z"/>
    </event>
  </trace>
</log>"#;

        fs::write(&log_path, xes_content).expect("Failed to write SBP1 test log");
        assert!(
            Path::new(&log_path).exists(),
            "SBP1 log file should be created"
        );

        let content = fs::read_to_string(&log_path).expect("Should read log");
        assert!(
            content.contains("enter_submitted"),
            "Should have state entry events"
        );
        assert!(
            content.contains("enter_under_review"),
            "Should have review state"
        );
        assert!(
            content.contains("enter_approved"),
            "Should have approved state"
        );
        assert!(content.contains("enter_closed"), "Should have closed state");
    }

    #[test]
    fn sbp1_state_machine_structure_verification() {
        // Verify structure by testing the create function directly
        let test_data_dir = get_test_data_dir();
        ensure_test_data_dir();

        // Check directory exists and can hold logs
        assert!(
            Path::new(&test_data_dir).exists(),
            "Test data directory should exist"
        );

        // Try to read existing SBP1 log, but don't fail if it doesn't exist
        let sbp1_path = format!("{}/state_machine_sbp1.xes", test_data_dir);
        let sbp1_test_path = format!("{}/state_machine_sbp1_test.xes", test_data_dir);

        for path in &[sbp1_path, sbp1_test_path] {
            if Path::new(path).exists() {
                let content = fs::read_to_string(path).expect("Should read log");
                if !content.is_empty() {
                    // Verify it has log structure
                    assert!(content.contains("<trace>"), "Should have traces");
                    return; // Test passes if we found a valid log
                }
            }
        }

        // If no valid logs found, that's OK - they'll be created by other tests
        // This is just a structure verification test
    }

    #[test]
    fn sbp1_state_machine_soundness_expected() {
        // This test FAILS initially (TDD) because we haven't implemented discovery yet
        // When implemented: discover net from log, then check soundness
        let log_path = create_state_machine_log();
        assert!(
            !log_path.is_empty(),
            "Log should exist for soundness checking"
        );

        // Expected: 4 states (submitted, under_review, (approved|denied), closed)
        // Expected: All transitions execute sequentially (no parallelism)
        // Expected: Single token at a time (marking shows current state)
        // Expected: All traces reach closed state (proper termination)

