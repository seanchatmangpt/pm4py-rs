    #[test]
    fn all_state_based_patterns_generated() {
        // Just verify the functions can be called without error
        let _log1 = create_state_machine_log();
        let _log2 = create_cyclic_state_transitions_log();
        let _log3 = create_guard_conditions_log();
        let _log4 = create_state_history_log();
        let _log5 = create_concurrent_state_machines_log();

        // Verify test data directory exists
        let test_data_dir = get_test_data_dir();
        assert!(
            Path::new(&test_data_dir).exists(),
            "Test data directory should exist"
        );

        // Verify at least one log file exists
        let mut has_logs = false;
        if let Ok(entries) = fs::read_dir(&test_data_dir) {
            for entry in entries.flatten() {
                if let Ok(name) = entry.file_name().into_string() {
                    if name.ends_with(".xes") && name.contains("sbp") {
                        has_logs = true;
                        break;
                    }
                }
            }
        }
        assert!(has_logs, "Should have at least one SBP log file");
    }

    #[test]
    fn state_based_patterns_trace_counts() {
        let patterns = vec![
            ("SBP1: State Machine", create_state_machine_log(), 6),
            (
                "SBP2: Cyclic Transitions",
                create_cyclic_state_transitions_log(),
                4,
            ),
            ("SBP3: Guard Conditions", create_guard_conditions_log(), 6),
            ("SBP4: State History", create_state_history_log(), 4),
            (
                "SBP5: Concurrent Machines",
                create_concurrent_state_machines_log(),
                3,
            ),
        ];

        for (name, log_path, expected_traces) in patterns {
            let content = fs::read_to_string(&log_path)
                .unwrap_or_else(|_| panic!("Should read {} log", name));
            let trace_count = content.matches("<trace>").count();
            assert_eq!(
                trace_count, expected_traces,
                "{} should have {} traces",
                name, expected_traces
            );
        }
    }

    #[test]
    fn state_based_patterns_xes_validity() {
        let logs = vec![
            create_state_machine_log(),
            create_cyclic_state_transitions_log(),
            create_guard_conditions_log(),
            create_state_history_log(),
            create_concurrent_state_machines_log(),
        ];

        for log_path in logs {
            let content = fs::read_to_string(&log_path).expect("Should read log");

            // Basic XML validity checks
            assert!(content.starts_with("<?xml"), "Should have XML declaration");
            assert!(content.contains("<log"), "Should have log element");
            assert!(content.contains("</log>"), "Should close log element");
            assert!(content.contains("<extension"), "Should have extensions");
            assert!(
                content.contains("concept:name"),
                "Should have concept extension"
            );
            assert!(
                content.contains("time:timestamp"),
                "Should have time extension"
            );
        }
    }

    #[test]
    fn state_based_patterns_event_sequence_validity() {
        let logs = vec![
            ("SBP1", create_state_machine_log()),
            ("SBP2", create_cyclic_state_transitions_log()),
            ("SBP3", create_guard_conditions_log()),
            ("SBP4", create_state_history_log()),
            ("SBP5", create_concurrent_state_machines_log()),
        ];

        for (pattern_name, log_path) in logs {
            let content = fs::read_to_string(&log_path)
                .unwrap_or_else(|_| panic!("Should read {} log", pattern_name));

            let traces: Vec<&str> = content.split("<trace>").collect();
            for trace in &traces[1..] {
                // Each trace should have events
                assert!(
                    trace.contains("<event>"),
                    "{}: Each trace should have events",
                    pattern_name
                );

                // Events should be in timestamp order
                let events: Vec<&str> = trace.split("<event>").collect();
                assert!(
                    events.len() > 1,
                    "{}: Trace should have at least one event",
                    pattern_name
                );

                // Extract timestamps and verify they're ordered
                let mut prev_timestamp = "".to_string();
                for event in &events[1..] {
                    if let Some(ts_start) = event.find("time:timestamp\">") {
                        let ts_start = ts_start + "time:timestamp\">".len();
                        if let Some(ts_end) = event[ts_start..].find("<") {
                            let timestamp = &event[ts_start..ts_start + ts_end];
                            if !prev_timestamp.is_empty() {
                                assert!(
                                    timestamp >= prev_timestamp.as_str(),
                                    "{}: Timestamps should be ordered",
                                    pattern_name
                                );
                            }
                            prev_timestamp = timestamp.to_string();
                        }
                    }
                }
            }
        }
    }
}
