    // ═══════════════════════════════════════════════════════════════════════════════
    // SBP2: CYCLIC STATE TRANSITIONS — States form cycles (iterations)
    // ═══════════════════════════════════════════════════════════════════════════════
    //
    // Pattern: States with cyclic (iterative) transitions
    // States: [initial, revision_requested, edit, resubmit, approved/rejected]
    // Cycle: edit → resubmit → (revision_requested | accepted)
    //
    // Structure:
    // - Multiple transitions between same pair of states (back-and-forth)
    // - Back-edge creates cycle in state graph
    // - Loop continues until termination condition (approved/rejected)
    //
    // Real-world: Document review with revision cycles
    // - Submit document
    // - Reviewer requests revision (may happen multiple times)
    // - Author edits and resubmits
    // - Process repeats until approved or rejected
    //
    // Traces (4 total):
    // - 1 trace: submit → approved (no revisions)
    // - 1 trace: submit → request_revision → edit → resubmit → approved (1 cycle)
    // - 1 trace: submit → request_revision → edit → resubmit → request_revision → edit → resubmit → approved (2 cycles)
    // - 1 trace: submit → request_revision → edit → resubmit → rejected (cycle then rejection)

    fn create_cyclic_state_transitions_log() -> String {
        let test_data_dir = get_test_data_dir();
        ensure_test_data_dir();

        let log_path = format!("{}/cyclic_state_transitions_sbp2.xes", test_data_dir);

        let xes_content = r#"<?xml version="1.0" encoding="UTF-8"?>
<log xes.version="1.0" xes.features="nested-attributes" xmlns="http://www.xes-standard.org/">
  <extension name="Concept" prefix="concept" uri="http://www.xes-standard.org/concept.xesext"/>
  <extension name="Time" prefix="time" uri="http://www.xes-standard.org/time.xesext"/>
  <global scope="trace">
    <string key="concept:name" value="case name"/>
  </global>
  <global scope="event">
    <string key="concept:name" value="activity name"/>
    <date key="time:timestamp" value="timestamp"/>
  </global>
  <!-- Trace 1: No revisions -->
  <trace>
    <string key="concept:name" value="doc_001"/>
    <event>
      <string key="concept:name" value="submit_document"/>
      <date key="time:timestamp" value="2024-01-01T10:00:00.000Z"/>
    </event>
    <event>
      <string key="concept:name" value="review_document"/>
      <date key="time:timestamp" value="2024-01-01T10:30:00.000Z"/>
    </event>
    <event>
      <string key="concept:name" value="approve_document"/>
      <date key="time:timestamp" value="2024-01-01T11:00:00.000Z"/>
    </event>
  </trace>
  <!-- Trace 2: One revision cycle -->
  <trace>
    <string key="concept:name" value="doc_002"/>
    <event>
      <string key="concept:name" value="submit_document"/>
      <date key="time:timestamp" value="2024-01-02T10:00:00.000Z"/>
    </event>
    <event>
      <string key="concept:name" value="review_document"/>
      <date key="time:timestamp" value="2024-01-02T10:30:00.000Z"/>
    </event>
    <event>
      <string key="concept:name" value="request_revision"/>
      <date key="time:timestamp" value="2024-01-02T11:00:00.000Z"/>
    </event>
    <event>
      <string key="concept:name" value="edit_document"/>
      <date key="time:timestamp" value="2024-01-02T14:00:00.000Z"/>
    </event>
    <event>
      <string key="concept:name" value="resubmit_document"/>
      <date key="time:timestamp" value="2024-01-02T14:30:00.000Z"/>
    </event>
    <event>
      <string key="concept:name" value="review_document"/>
      <date key="time:timestamp" value="2024-01-02T15:00:00.000Z"/>
    </event>
    <event>
      <string key="concept:name" value="approve_document"/>
      <date key="time:timestamp" value="2024-01-02T15:30:00.000Z"/>
    </event>
  </trace>
  <!-- Trace 3: Two revision cycles -->
  <trace>
    <string key="concept:name" value="doc_003"/>
    <event>
      <string key="concept:name" value="submit_document"/>
