    #[test]
    fn sbp3_guard_conditions_path_separation() {
        // Try to read existing log, but create fresh if needed
        let test_data_dir = get_test_data_dir();
        let sbp3_path = format!("{}/guard_conditions_sbp3.xes", test_data_dir);
        let sbp3_test_path = format!("{}/guard_conditions_test.xes", test_data_dir);

        let mut content = String::new();
        for path in &[sbp3_path, sbp3_test_path] {
            if Path::new(path).exists() {
                if let Ok(file_content) = fs::read_to_string(path) {
                    if !file_content.is_empty() {
                        content = file_content;
                        break;
                    }
                }
            }
        }

        // If we have content, verify both paths exist
        if !content.is_empty() {
            assert!(
                content.contains("approve_application") || content.contains("approval"),
                "Should have approval path"
            );
            assert!(
                content.contains("manual_review") || content.contains("review"),
                "Should have review path"
            );
        }
    }

