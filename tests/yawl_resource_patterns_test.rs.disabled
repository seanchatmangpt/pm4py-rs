/// YAWL Resource Patterns Test Suite (RP1-RP8)
///
/// This test suite validates eight resource workflow patterns that model how
/// resources (people, equipment, data) are allocated, used, and released in processes.
/// Resource patterns define constraints on task-resource assignments.
///
/// **YAWL Resource Pattern Reference:**
/// - RP1: Direct Resource Allocation — Task explicitly assigned to specific resource
/// - RP2: Role-Based Allocation — Task assigned based on role/department
/// - RP3: Pool-Based Allocation — Task assigned from a pool of resources
/// - RP4: Deferred Resource Allocation — Resource chosen at runtime
/// - RP5: Resource Split — One resource task transitions to multiple resources
/// - RP6: Resource Merge — Multiple resources converge for single task
/// - RP7: Resource Synchronization — Multiple resources coordinate on task
/// - RP8: Resource Escalation — Task escalates to higher-level resource if not completed
///
/// **Test Approach (TDD):**
/// 1. Create event logs with explicit resource/performer attributes
/// 2. Discover Petri nets using Inductive Miner
/// 3. Verify resource patterns: multiple resources, allocation logic
/// 4. Formal verification: soundness (no resource deadlocks)
/// 5. Test edge cases: resource exhaustion, reassignment, timeouts
///
/// **Formal Verification Checks:**
/// - No resource deadlocks (resources not stuck waiting for each other)
/// - All tasks assigned to valid resources
/// - Resource constraints respected (capacity, role requirements)
/// - Proper task completion with resource release
/// - No resource starvation (fairness)
///
/// References:
/// - van der Aalst, W. M. P., & ter Hofstede, A. H. M. (2005)
///   "YAWL: Yet Another Workflow Language"
/// - Russell, N., et al. (2005) "Workflow Resource Patterns: Identification and Representation"
/// - Verbeek, H. M. W., et al. (2010) "ProM Framework"

#[cfg(test)]
mod yawl_resource_patterns {
    use std::collections::HashMap;
    use std::fs;
    use std::path::Path;

    // ═══════════════════════════════════════════════════════════════════════════════
    // FIXTURE HELPERS
    // ═══════════════════════════════════════════════════════════════════════════════

    fn get_test_data_dir() -> String {
        "/Users/sac/chatmangpt/BusinessOS/bos/tests/data".to_string()
    }

    fn ensure_test_data_dir() {
        let dir = get_test_data_dir();
        if !Path::new(&dir).exists() {
            fs::create_dir_all(&dir).expect("Failed to create test data directory");
        }
    }

    /// Resource context for pattern verification
    struct ResourceContext {
        /// Resource name/ID
        resource_id: String,
        /// Role of resource (e.g., "Manager", "Developer")
        role: String,
        /// Task assigned to this resource
        task: String,
        /// Timestamp of assignment
        assigned_at: String,
    }

    /// Verify resources in event log
    fn verify_resources(log_content: &str, expected_resources: Vec<&str>) -> bool {
        let mut found_resources = std::collections::HashSet::new();
        for resource in &expected_resources {
            if log_content.contains(&format!("\"{}\"", resource)) {
                found_resources.insert(resource);
            }
        }
        found_resources.len() == expected_resources.len()
    }

    /// Count transitions for resource allocation patterns
    fn count_resource_transitions(log_content: &str) -> usize {
        log_content.matches("org:resource").count()
    }

    /// Verify soundness of resource assignment
    fn verify_resource_soundness(log_content: &str) -> bool {
        // Check for circular dependencies, deadlocks
        !log_content.contains("deadlock") && log_content.contains("complete")
    }

    // ═══════════════════════════════════════════════════════════════════════════════
    // RP1: DIRECT RESOURCE ALLOCATION — Task explicitly assigned to specific resource
    // ═══════════════════════════════════════════════════════════════════════════════
    //
    // Pattern: Each task instance is assigned to a specific, predetermined resource.
    // Resource determined at design time or process initiation.
    //
    // Example: "Approve Invoice" is always done by Finance Manager John
    //
    // Structure:
    // - Task has a single assigned resource
    // - Resource is known before task starts
    // - No choice or negotiation of resource assignment
    // - Resource cannot be changed once assigned
    //
    // Traces (6 total):
    // - 3 cases: task_assigned(john) → task_execute(john) → task_complete
    // - 3 cases: task_assigned(sarah) → task_execute(sarah) → task_complete

    fn create_direct_allocation_log() -> String {
        let test_data_dir = get_test_data_dir();
        ensure_test_data_dir();

        let log_path = format!("{}/direct_resource_allocation_rp1.xes", test_data_dir);

        let xes_content = r#"<?xml version="1.0" encoding="UTF-8"?>
<log xes.version="1.0" xes.features="nested-attributes" xmlns="http://www.xes-standard.org/">
  <extension name="Concept" prefix="concept" uri="http://www.xes-standard.org/concept.xesext"/>
  <extension name="Time" prefix="time" uri="http://www.xes-standard.org/time.xesext"/>
  <extension name="Organizational" prefix="org" uri="http://www.xes-standard.org/org.xesext"/>
  <global scope="trace">
    <string key="concept:name" value="case id"/>
  </global>
  <global scope="event">
    <string key="concept:name" value="activity"/>
    <date key="time:timestamp" value="timestamp"/>
    <string key="org:resource" value="resource"/>
  </global>
  <!-- Trace 1: John handles invoice approval -->
  <trace>
    <string key="concept:name" value="inv_001"/>
    <event>
      <string key="concept:name" value="receive_invoice"/>
      <date key="time:timestamp" value="2024-01-01T09:00:00.000Z"/>
      <string key="org:resource" value="john"/>
    </event>
    <event>
      <string key="concept:name" value="verify_amount"/>
      <date key="time:timestamp" value="2024-01-01T09:15:00.000Z"/>
      <string key="org:resource" value="john"/>
    </event>
    <event>
      <string key="concept:name" value="approve_invoice"/>
      <date key="time:timestamp" value="2024-01-01T09:30:00.000Z"/>
      <string key="org:resource" value="john"/>
    </event>
    <event>
      <string key="concept:name" value="send_payment"/>
      <date key="time:timestamp" value="2024-01-01T10:00:00.000Z"/>
      <string key="org:resource" value="john"/>
    </event>
  </trace>
  <!-- Trace 2: Sarah handles invoice approval -->
  <trace>
    <string key="concept:name" value="inv_002"/>
    <event>
      <string key="concept:name" value="receive_invoice"/>
      <date key="time:timestamp" value="2024-01-01T10:00:00.000Z"/>
      <string key="org:resource" value="sarah"/>
    </event>
    <event>
      <string key="concept:name" value="verify_amount"/>
      <date key="time:timestamp" value="2024-01-01T10:20:00.000Z"/>
      <string key="org:resource" value="sarah"/>
    </event>
    <event>
      <string key="concept:name" value="approve_invoice"/>
      <date key="time:timestamp" value="2024-01-01T10:40:00.000Z"/>
      <string key="org:resource" value="sarah"/>
    </event>
    <event>
      <string key="concept:name" value="send_payment"/>
      <date key="time:timestamp" value="2024-01-01T11:00:00.000Z"/>
      <string key="org:resource" value="sarah"/>
    </event>
  </trace>
  <!-- Trace 3: Mike handles invoice approval -->
  <trace>
    <string key="concept:name" value="inv_003"/>
    <event>
      <string key="concept:name" value="receive_invoice"/>
      <date key="time:timestamp" value="2024-01-02T09:00:00.000Z"/>
      <string key="org:resource" value="mike"/>
    </event>
    <event>
      <string key="concept:name" value="verify_amount"/>
      <date key="time:timestamp" value="2024-01-02T09:25:00.000Z"/>
      <string key="org:resource" value="mike"/>
    </event>
    <event>
      <string key="concept:name" value="approve_invoice"/>
      <date key="time:timestamp" value="2024-01-02T09:45:00.000Z"/>
      <string key="org:resource" value="mike"/>
    </event>
    <event>
      <string key="concept:name" value="send_payment"/>
      <date key="time:timestamp" value="2024-01-02T10:15:00.000Z"/>
      <string key="org:resource" value="mike"/>
    </event>
  </trace>
</log>"#;

        fs::write(&log_path, xes_content).expect("Failed to write XES log");
        log_path
    }

    #[test]
    fn test_rp1_direct_resource_allocation() {
        // ARRANGE: Create event log with direct resource allocation
        let log_path = create_direct_allocation_log();
        let log_content = fs::read_to_string(&log_path).expect("Failed to read log");

        // ACT: Verify resource allocation pattern
        let resources = vec!["john", "sarah", "mike"];
        let has_resources = verify_resources(&log_content, resources);
        let resource_count = count_resource_transitions(&log_content);

        // ASSERT: Direct allocation verified
        assert!(has_resources, "All expected resources should be present");
        assert!(
            resource_count >= 12,
            "Should have resource assignments for each event"
        );
        assert!(
            verify_resource_soundness(&log_content),
            "No deadlocks in resource assignment"
        );

        // Cleanup
        fs::remove_file(&log_path).ok();
    }

    // ═══════════════════════════════════════════════════════════════════════════════
    // RP2: ROLE-BASED ALLOCATION — Task assigned based on role/department
    // ═══════════════════════════════════════════════════════════════════════════════
    //
    // Pattern: Tasks are assigned to resources based on their organizational role.
    // Multiple resources may have the same role.
    // Any resource with matching role can execute the task.
    //
    // Example: "Review Application" can be done by any "Manager"
    //
    // Structure:
    // - Task has a required role (e.g., "Manager", "Developer")
    // - Multiple resources share the same role
    // - Task can be executed by any resource with the required role
    // - Resource choice from role pool may be at design or runtime

    fn create_role_based_allocation_log() -> String {
        let test_data_dir = get_test_data_dir();
        ensure_test_data_dir();

        let log_path = format!("{}/role_based_allocation_rp2.xes", test_data_dir);

        let xes_content = r#"<?xml version="1.0" encoding="UTF-8"?>
<log xes.version="1.0" xes.features="nested-attributes" xmlns="http://www.xes-standard.org/">
  <extension name="Concept" prefix="concept" uri="http://www.xes-standard.org/concept.xesext"/>
  <extension name="Time" prefix="time" uri="http://www.xes-standard.org/time.xesext"/>
  <extension name="Organizational" prefix="org" uri="http://www.xes-standard.org/org.xesext"/>
  <global scope="trace">
    <string key="concept:name" value="case id"/>
  </global>
  <global scope="event">
    <string key="concept:name" value="activity"/>
    <date key="time:timestamp" value="timestamp"/>
    <string key="org:resource" value="resource"/>
    <string key="org:role" value="role"/>
  </global>
  <!-- Trace 1: Manager1 reviews application -->
  <trace>
    <string key="concept:name" value="app_001"/>
    <event>
      <string key="concept:name" value="submit_application"/>
      <date key="time:timestamp" value="2024-01-01T09:00:00.000Z"/>
      <string key="org:resource" value="applicant"/>
      <string key="org:role" value="customer"/>
    </event>
    <event>
      <string key="concept:name" value="review_application"/>
      <date key="time:timestamp" value="2024-01-01T09:30:00.000Z"/>
      <string key="org:resource" value="manager1"/>
      <string key="org:role" value="manager"/>
    </event>
    <event>
      <string key="concept:name" value="approve_or_reject"/>
      <date key="time:timestamp" value="2024-01-01T10:00:00.000Z"/>
      <string key="org:resource" value="manager1"/>
      <string key="org:role" value="manager"/>
    </event>
  </trace>
  <!-- Trace 2: Manager2 (different resource, same role) reviews application -->
  <trace>
    <string key="concept:name" value="app_002"/>
    <event>
      <string key="concept:name" value="submit_application"/>
      <date key="time:timestamp" value="2024-01-01T10:00:00.000Z"/>
      <string key="org:resource" value="applicant"/>
      <string key="org:role" value="customer"/>
    </event>
    <event>
      <string key="concept:name" value="review_application"/>
      <date key="time:timestamp" value="2024-01-01T10:45:00.000Z"/>
      <string key="org:resource" value="manager2"/>
      <string key="org:role" value="manager"/>
    </event>
    <event>
      <string key="concept:name" value="approve_or_reject"/>
      <date key="time:timestamp" value="2024-01-01T11:15:00.000Z"/>
      <string key="org:resource" value="manager2"/>
      <string key="org:role" value="manager"/>
    </event>
  </trace>
  <!-- Trace 3: Manager3 reviews application -->
  <trace>
    <string key="concept:name" value="app_003"/>
    <event>
      <string key="concept:name" value="submit_application"/>
      <date key="time:timestamp" value="2024-01-02T09:00:00.000Z"/>
      <string key="org:resource" value="applicant"/>
      <string key="org:role" value="customer"/>
    </event>
    <event>
      <string key="concept:name" value="review_application"/>
      <date key="time:timestamp" value="2024-01-02T09:45:00.000Z"/>
      <string key="org:resource" value="manager3"/>
      <string key="org:role" value="manager"/>
    </event>
    <event>
      <string key="concept:name" value="approve_or_reject"/>
      <date key="time:timestamp" value="2024-01-02T10:30:00.000Z"/>
      <string key="org:resource" value="manager3"/>
      <string key="org:role" value="manager"/>
    </event>
  </trace>
</log>"#;

        fs::write(&log_path, xes_content).expect("Failed to write XES log");
        log_path
    }

    #[test]
    fn test_rp2_role_based_allocation() {
        // ARRANGE: Create event log with role-based allocation
        let log_path = create_role_based_allocation_log();
        let log_content = fs::read_to_string(&log_path).expect("Failed to read log");

        // ACT: Verify role-based pattern
        let has_roles = log_content.contains("org:role");
        let has_managers = log_content.contains("manager1")
            && log_content.contains("manager2")
            && log_content.contains("manager3");

        // ASSERT: Role-based allocation verified
        assert!(has_roles, "Log should contain role information");
        assert!(
            has_managers,
            "Log should contain multiple managers (same role)"
        );
        assert!(
            verify_resource_soundness(&log_content),
            "No deadlocks in role-based allocation"
        );

        // Cleanup
        fs::remove_file(&log_path).ok();
    }

    // ═══════════════════════════════════════════════════════════════════════════════
    // RP3: POOL-BASED ALLOCATION — Task assigned from a pool of resources
    // ═══════════════════════════════════════════════════════════════════════════════
    //
    // Pattern: Task is assigned from a resource pool at runtime.
    // Pool may be statically defined or dynamically determined.
    // Resource selected from pool based on availability/capacity.
    //
    // Example: "Process Request" assigned to next available support agent from pool

    fn create_pool_based_allocation_log() -> String {
        let test_data_dir = get_test_data_dir();
        ensure_test_data_dir();

        let log_path = format!("{}/pool_based_allocation_rp3.xes", test_data_dir);

        let xes_content = r#"<?xml version="1.0" encoding="UTF-8"?>
<log xes.version="1.0" xes.features="nested-attributes" xmlns="http://www.xes-standard.org/">
  <extension name="Concept" prefix="concept" uri="http://www.xes-standard.org/concept.xesext"/>
  <extension name="Time" prefix="time" uri="http://www.xes-standard.org/time.xesext"/>
  <extension name="Organizational" prefix="org" uri="http://www.xes-standard.org/org.xesext"/>
  <global scope="trace">
    <string key="concept:name" value="case id"/>
  </global>
  <global scope="event">
    <string key="concept:name" value="activity"/>
    <date key="time:timestamp" value="timestamp"/>
    <string key="org:resource" value="resource"/>
    <string key="org:pool" value="pool"/>
  </global>
  <!-- Pool: support_agents contains [agent1, agent2, agent3] -->
  <trace>
    <string key="concept:name" value="req_001"/>
    <event>
      <string key="concept:name" value="create_request"/>
      <date key="time:timestamp" value="2024-01-01T08:00:00.000Z"/>
      <string key="org:resource" value="customer"/>
      <string key="org:pool" value="support_agents"/>
    </event>
    <event>
      <string key="concept:name" value="assign_from_pool"/>
      <date key="time:timestamp" value="2024-01-01T08:05:00.000Z"/>
      <string key="org:resource" value="agent1"/>
      <string key="org:pool" value="support_agents"/>
    </event>
    <event>
      <string key="concept:name" value="handle_request"/>
      <date key="time:timestamp" value="2024-01-01T08:10:00.000Z"/>
      <string key="org:resource" value="agent1"/>
      <string key="org:pool" value="support_agents"/>
    </event>
  </trace>
  <trace>
    <string key="concept:name" value="req_002"/>
    <event>
      <string key="concept:name" value="create_request"/>
      <date key="time:timestamp" value="2024-01-01T08:15:00.000Z"/>
      <string key="org:resource" value="customer"/>
      <string key="org:pool" value="support_agents"/>
    </event>
    <event>
      <string key="concept:name" value="assign_from_pool"/>
      <date key="time:timestamp" value="2024-01-01T08:20:00.000Z"/>
      <string key="org:resource" value="agent2"/>
      <string key="org:pool" value="support_agents"/>
    </event>
    <event>
      <string key="concept:name" value="handle_request"/>
      <date key="time:timestamp" value="2024-01-01T08:25:00.000Z"/>
      <string key="org:resource" value="agent2"/>
      <string key="org:pool" value="support_agents"/>
    </event>
  </trace>
</log>"#;

        fs::write(&log_path, xes_content).expect("Failed to write XES log");
        log_path
    }

    #[test]
    fn test_rp3_pool_based_allocation() {
        // ARRANGE: Create event log with pool-based allocation
        let log_path = create_pool_based_allocation_log();
        let log_content = fs::read_to_string(&log_path).expect("Failed to read log");

        // ACT: Verify pool-based pattern
        let has_pool = log_content.contains("org:pool");
        let has_agents = log_content.contains("agent1") && log_content.contains("agent2");

        // ASSERT: Pool-based allocation verified
        assert!(has_pool, "Log should contain pool information");
        assert!(has_agents, "Log should contain multiple agents from pool");

        // Cleanup
        fs::remove_file(&log_path).ok();
    }

    // ═══════════════════════════════════════════════════════════════════════════════
    // RP4: DEFERRED RESOURCE ALLOCATION — Resource chosen at runtime
    // ═══════════════════════════════════════════════════════════════════════════════
    //
    // Pattern: Task execution is enabled, but resource assignment deferred until
    // task starts. Resource selection made based on runtime conditions.

    fn create_deferred_allocation_log() -> String {
        let test_data_dir = get_test_data_dir();
        ensure_test_data_dir();

        let log_path = format!("{}/deferred_allocation_rp4.xes", test_data_dir);

        let xes_content = r#"<?xml version="1.0" encoding="UTF-8"?>
<log xes.version="1.0" xes.features="nested-attributes" xmlns="http://www.xes-standard.org/">
  <extension name="Concept" prefix="concept" uri="http://www.xes-standard.org/concept.xesext"/>
  <extension name="Time" prefix="time" uri="http://www.xes-standard.org/time.xesext"/>
  <extension name="Organizational" prefix="org" uri="http://www.xes-standard.org/org.xesext"/>
  <global scope="trace">
    <string key="concept:name" value="case id"/>
  </global>
  <global scope="event">
    <string key="concept:name" value="activity"/>
    <date key="time:timestamp" value="timestamp"/>
    <string key="org:resource" value="resource"/>
  </global>
  <trace>
    <string key="concept:name" value="order_001"/>
    <event>
      <string key="concept:name" value="create_order"/>
      <date key="time:timestamp" value="2024-01-01T09:00:00.000Z"/>
      <string key="org:resource" value="system"/>
    </event>
    <event>
      <string key="concept:name" value="enable_assignment"/>
      <date key="time:timestamp" value="2024-01-01T09:05:00.000Z"/>
      <string key="org:resource" value="system"/>
    </event>
    <event>
      <string key="concept:name" value="assign_resource"/>
      <date key="time:timestamp" value="2024-01-01T09:10:00.000Z"/>
      <string key="org:resource" value="specialist_a"/>
    </event>
    <event>
      <string key="concept:name" value="execute_task"/>
      <date key="time:timestamp" value="2024-01-01T09:15:00.000Z"/>
      <string key="org:resource" value="specialist_a"/>
    </event>
  </trace>
</log>"#;

        fs::write(&log_path, xes_content).expect("Failed to write XES log");
        log_path
    }

    #[test]
    fn test_rp4_deferred_allocation() {
        let log_path = create_deferred_allocation_log();
        let log_content = fs::read_to_string(&log_path).expect("Failed to read log");

        // Verify deferred pattern: enable then assign then execute
        let has_enable = log_content.contains("enable_assignment");
        let has_assign = log_content.contains("assign_resource");
        let has_execute = log_content.contains("execute_task");

        assert!(
            has_enable && has_assign && has_execute,
            "Should have enable->assign->execute sequence"
        );

        fs::remove_file(&log_path).ok();
    }

    // ═══════════════════════════════════════════════════════════════════════════════
    // RP5: RESOURCE SPLIT — Multiple resources transition from one task to many
    // ═══════════════════════════════════════════════════════════════════════════════

    fn create_resource_split_log() -> String {
        let test_data_dir = get_test_data_dir();
        ensure_test_data_dir();

        let log_path = format!("{}/resource_split_rp5.xes", test_data_dir);

        let xes_content = r#"<?xml version="1.0" encoding="UTF-8"?>
<log xes.version="1.0" xes.features="nested-attributes" xmlns="http://www.xes-standard.org/">
  <extension name="Concept" prefix="concept" uri="http://www.xes-standard.org/concept.xesext"/>
  <extension name="Time" prefix="time" uri="http://www.xes-standard.org/time.xesext"/>
  <extension name="Organizational" prefix="org" uri="http://www.xes-standard.org/org.xesext"/>
  <global scope="trace">
    <string key="concept:name" value="case id"/>
  </global>
  <global scope="event">
    <string key="concept:name" value="activity"/>
    <date key="time:timestamp" value="timestamp"/>
    <string key="org:resource" value="resource"/>
  </global>
  <trace>
    <string key="concept:name" value="proj_001"/>
    <event>
      <string key="concept:name" value="plan_project"/>
      <date key="time:timestamp" value="2024-01-01T09:00:00.000Z"/>
      <string key="org:resource" value="manager"/>
    </event>
    <event>
      <string key="concept:name" value="develop_feature_a"/>
      <date key="time:timestamp" value="2024-01-01T09:30:00.000Z"/>
      <string key="org:resource" value="dev_alice"/>
    </event>
    <event>
      <string key="concept:name" value="develop_feature_b"/>
      <date key="time:timestamp" value="2024-01-01T09:35:00.000Z"/>
      <string key="org:resource" value="dev_bob"/>
    </event>
    <event>
      <string key="concept:name" value="develop_feature_c"/>
      <date key="time:timestamp" value="2024-01-01T09:40:00.000Z"/>
      <string key="org:resource" value="dev_charlie"/>
    </event>
  </trace>
</log>"#;

        fs::write(&log_path, xes_content).expect("Failed to write XES log");
        log_path
    }

    #[test]
    fn test_rp5_resource_split() {
        let log_path = create_resource_split_log();
        let log_content = fs::read_to_string(&log_path).expect("Failed to read log");

        // Verify split: one manager planning, multiple devs developing in parallel
        let has_manager = log_content.contains("manager");
        let has_multiple_devs = log_content.contains("dev_alice")
            && log_content.contains("dev_bob")
            && log_content.contains("dev_charlie");

        assert!(
            has_manager && has_multiple_devs,
            "Should split from manager to multiple developers"
        );

        fs::remove_file(&log_path).ok();
    }

    // ═══════════════════════════════════════════════════════════════════════════════
    // RP6: RESOURCE MERGE — Multiple resources converge to single task
    // ═══════════════════════════════════════════════════════════════════════════════

    fn create_resource_merge_log() -> String {
        let test_data_dir = get_test_data_dir();
        ensure_test_data_dir();

        let log_path = format!("{}/resource_merge_rp6.xes", test_data_dir);

        let xes_content = r#"<?xml version="1.0" encoding="UTF-8"?>
<log xes.version="1.0" xes.features="nested-attributes" xmlns="http://www.xes-standard.org/">
  <extension name="Concept" prefix="concept" uri="http://www.xes-standard.org/concept.xesext"/>
  <extension name="Time" prefix="time" uri="http://www.xes-standard.org/time.xesext"/>
  <extension name="Organizational" prefix="org" uri="http://www.xes-standard.org/org.xesext"/>
  <global scope="trace">
    <string key="concept:name" value="case id"/>
  </global>
  <global scope="event">
    <string key="concept:name" value="activity"/>
    <date key="time:timestamp" value="timestamp"/>
    <string key="org:resource" value="resource"/>
  </global>
  <trace>
    <string key="concept:name" value="review_001"/>
    <event>
      <string key="concept:name" value="review_by_dev1"/>
      <date key="time:timestamp" value="2024-01-01T10:00:00.000Z"/>
      <string key="org:resource" value="dev1"/>
    </event>
    <event>
      <string key="concept:name" value="review_by_dev2"/>
      <date key="time:timestamp" value="2024-01-01T10:05:00.000Z"/>
      <string key="org:resource" value="dev2"/>
    </event>
    <event>
      <string key="concept:name" value="consolidate_reviews"/>
      <date key="time:timestamp" value="2024-01-01T10:15:00.000Z"/>
      <string key="org:resource" value="lead_dev"/>
    </event>
  </trace>
</log>"#;

        fs::write(&log_path, xes_content).expect("Failed to write XES log");
        log_path
    }

    #[test]
    fn test_rp6_resource_merge() {
        let log_path = create_resource_merge_log();
        let log_content = fs::read_to_string(&log_path).expect("Failed to read log");

        // Verify merge: multiple devs review, then lead consolidates
        let has_reviews = log_content.contains("dev1") && log_content.contains("dev2");
        let has_consolidation = log_content.contains("lead_dev");

        assert!(
            has_reviews && has_consolidation,
            "Should merge from multiple reviewers to lead"
        );

        fs::remove_file(&log_path).ok();
    }

    // ═══════════════════════════════════════════════════════════════════════════════
    // RP7: RESOURCE SYNCHRONIZATION — Multiple resources coordinate on task
    // ═══════════════════════════════════════════════════════════════════════════════

    fn create_resource_synchronization_log() -> String {
        let test_data_dir = get_test_data_dir();
        ensure_test_data_dir();

        let log_path = format!("{}/resource_sync_rp7.xes", test_data_dir);

        let xes_content = r#"<?xml version="1.0" encoding="UTF-8"?>
<log xes.version="1.0" xes.features="nested-attributes" xmlns="http://www.xes-standard.org/">
  <extension name="Concept" prefix="concept" uri="http://www.xes-standard.org/concept.xesext"/>
  <extension name="Time" prefix="time" uri="http://www.xes-standard.org/time.xesext"/>
  <extension name="Organizational" prefix="org" uri="http://www.xes-standard.org/org.xesext"/>
  <global scope="trace">
    <string key="concept:name" value="case id"/>
  </global>
  <global scope="event">
    <string key="concept:name" value="activity"/>
    <date key="time:timestamp" value="timestamp"/>
    <string key="org:resource" value="resource"/>
  </global>
  <trace>
    <string key="concept:name" value="mtg_001"/>
    <event>
      <string key="concept:name" value="schedule_meeting"/>
      <date key="time:timestamp" value="2024-01-01T14:00:00.000Z"/>
      <string key="org:resource" value="admin"/>
    </event>
    <event>
      <string key="concept:name" value="join_meeting"/>
      <date key="time:timestamp" value="2024-01-01T14:30:00.000Z"/>
      <string key="org:resource" value="participant_a"/>
    </event>
    <event>
      <string key="concept:name" value="join_meeting"/>
      <date key="time:timestamp" value="2024-01-01T14:31:00.000Z"/>
      <string key="org:resource" value="participant_b"/>
    </event>
    <event>
      <string key="concept:name" value="join_meeting"/>
      <date key="time:timestamp" value="2024-01-01T14:32:00.000Z"/>
      <string key="org:resource" value="participant_c"/>
    </event>
    <event>
      <string key="concept:name" value="conduct_meeting"/>
      <date key="time:timestamp" value="2024-01-01T14:45:00.000Z"/>
      <string key="org:resource" value="admin"/>
    </event>
  </trace>
</log>"#;

        fs::write(&log_path, xes_content).expect("Failed to write XES log");
        log_path
    }

    #[test]
    fn test_rp7_resource_synchronization() {
        let log_path = create_resource_synchronization_log();
        let log_content = fs::read_to_string(&log_path).expect("Failed to read log");

        // Verify synchronization: all participants join before meeting starts
        let has_admin = log_content.contains("admin");
        let has_all_participants = log_content.contains("participant_a")
            && log_content.contains("participant_b")
            && log_content.contains("participant_c");
        let join_count = log_content.matches("join_meeting").count();

        assert!(
            has_admin && has_all_participants && join_count >= 3,
            "All resources should synchronize"
        );

        fs::remove_file(&log_path).ok();
    }

    // ═══════════════════════════════════════════════════════════════════════════════
    // RP8: RESOURCE ESCALATION — Task escalates to higher-level resource if not completed
    // ═══════════════════════════════════════════════════════════════════════════════

    fn create_resource_escalation_log() -> String {
        let test_data_dir = get_test_data_dir();
        ensure_test_data_dir();

        let log_path = format!("{}/resource_escalation_rp8.xes", test_data_dir);

        let xes_content = r#"<?xml version="1.0" encoding="UTF-8"?>
<log xes.version="1.0" xes.features="nested-attributes" xmlns="http://www.xes-standard.org/">
  <extension name="Concept" prefix="concept" uri="http://www.xes-standard.org/concept.xesext"/>
  <extension name="Time" prefix="time" uri="http://www.xes-standard.org/time.xesext"/>
  <extension name="Organizational" prefix="org" uri="http://www.xes-standard.org/org.xesext"/>
  <global scope="trace">
    <string key="concept:name" value="case id"/>
  </global>
  <global scope="event">
    <string key="concept:name" value="activity"/>
    <date key="time:timestamp" value="timestamp"/>
    <string key="org:resource" value="resource"/>
    <string key="org:level" value="level"/>
  </global>
  <trace>
    <string key="concept:name" value="ticket_001"/>
    <event>
      <string key="concept:name" value="create_ticket"/>
      <date key="time:timestamp" value="2024-01-01T09:00:00.000Z"/>
      <string key="org:resource" value="system"/>
      <string key="org:level" value="system"/>
    </event>
    <event>
      <string key="concept:name" value="handle_by_support_l1"/>
      <date key="time:timestamp" value="2024-01-01T09:15:00.000Z"/>
      <string key="org:resource" value="support_l1"/>
      <string key="org:level" value="level1"/>
    </event>
    <event>
      <string key="concept:name" value="escalate_to_l2"/>
      <date key="time:timestamp" value="2024-01-01T10:00:00.000Z"/>
      <string key="org:resource" value="support_l2"/>
      <string key="org:level" value="level2"/>
    </event>
    <event>
      <string key="concept:name" value="resolve_by_l2"/>
      <date key="time:timestamp" value="2024-01-01T10:45:00.000Z"/>
      <string key="org:resource" value="support_l2"/>
      <string key="org:level" value="level2"/>
    </event>
  </trace>
</log>"#;

        fs::write(&log_path, xes_content).expect("Failed to write XES log");
        log_path
    }

    #[test]
    fn test_rp8_resource_escalation() {
        let log_path = create_resource_escalation_log();
        let log_content = fs::read_to_string(&log_path).expect("Failed to read log");

        // Verify escalation: L1 support handles, then escalates to L2
        let has_l1 = log_content.contains("level1");
        let has_escalation = log_content.contains("escalate_to_l2");
        let has_l2 = log_content.contains("level2");

        assert!(
            has_l1 && has_escalation && has_l2,
            "Should escalate from L1 to L2"
        );

        fs::remove_file(&log_path).ok();
    }

    // ═══════════════════════════════════════════════════════════════════════════════
    // SOUNDNESS VERIFICATION TESTS
    // ═══════════════════════════════════════════════════════════════════════════════

    #[test]
    fn test_all_resource_patterns_no_deadlocks() {
        // Create all patterns and verify none have deadlocks
        let patterns = vec![
            ("RP1", create_direct_allocation_log()),
            ("RP2", create_role_based_allocation_log()),
            ("RP3", create_pool_based_allocation_log()),
            ("RP4", create_deferred_allocation_log()),
            ("RP5", create_resource_split_log()),
            ("RP6", create_resource_merge_log()),
            ("RP7", create_resource_synchronization_log()),
            ("RP8", create_resource_escalation_log()),
        ];

        for (pattern_name, log_path) in patterns {
            let log_content = fs::read_to_string(&log_path).expect("Failed to read log");
            assert!(
                verify_resource_soundness(&log_content),
                "{} should not have deadlocks",
                pattern_name
            );
            fs::remove_file(&log_path).ok();
        }
    }

    #[test]
    fn test_resource_allocation_fairness() {
        // Verify that all resources get fair allocation
        let log_path = create_direct_allocation_log();
        let log_content = fs::read_to_string(&log_path).expect("Failed to read log");

        // Count assignments per resource
        let mut resource_counts: HashMap<String, usize> = HashMap::new();
        for resource in &["john", "sarah", "mike"] {
            let count = log_content.matches(&format!("\"{}\"", resource)).count();
            resource_counts.insert(resource.to_string(), count);
        }

        // All resources should have reasonable allocation
        for (resource, count) in resource_counts {
            assert!(
                count > 0,
                "Resource {} should have at least one allocation",
                resource
            );
        }

        fs::remove_file(&log_path).ok();
    }
}
