//! YAWL Bridge Gap Closure Tests
//!
//! Covers three gaps identified in `src/yawl/`:
//!   1. GatewayCode::Or variant is accessible and constructible.
//!   2. classify_join_split never returns Or — documents the known gap.
//!   3. petri_net_to_yawl_xml / build_yawl_xml does not emit arc weights — guards the gap.
//!   4. check_conformance returns Ok(ConformanceResponse) on a happy HTTP path via mockito.
//!
//! Run: cargo test --test yawl_bridge_test

use pm4py::yawl::spec_builder::{classify_join_split, build_yawl_xml, GatewayCode};
use pm4py::yawl::{YawlClient, petri_net_to_yawl_xml};

// ─────────────────────────────────────────────────────────────────────────────
// Test 1: GatewayCode::Or is constructible (dead-code suppression proof)
// ─────────────────────────────────────────────────────────────────────────────

#[test]
fn test_gateway_code_or_is_constructible() {
    // GatewayCode::Or must be constructible without triggering a dead_code warning
    // at the call site, and must match the Or arm of the enum.
    let code = GatewayCode::Or;
    assert!(matches!(code, GatewayCode::Or));
    assert_eq!(code.as_str(), "or");
}

// ─────────────────────────────────────────────────────────────────────────────
// Test 2: classify_join_split never returns Or — documents the reachability gap
//
// Current implementation:
//   join  = if in_count > 1 { And } else { Xor }
//   split = And (always)
//
// There is NO input (in_count, out_count) that produces GatewayCode::Or.
// This test documents that invariant explicitly so any future change that
// introduces Or-reachability will need to update this test.
// ─────────────────────────────────────────────────────────────────────────────

#[test]
fn test_classify_join_split_never_returns_or() {
    // Exhaustive check over representative arc counts (0–5 in, 0–5 out)
    for in_count in 0..=5 {
        for out_count in 0..=5 {
            let (join, split) = classify_join_split(in_count, out_count);
            assert_ne!(
                join,
                GatewayCode::Or,
                "classify_join_split({in_count}, {out_count}) produced Or join — \
                 implementation does not support Or reachability yet"
            );
            assert_ne!(
                split,
                GatewayCode::Or,
                "classify_join_split({in_count}, {out_count}) produced Or split — \
                 implementation does not support Or reachability yet"
            );
        }
    }
}

// ─────────────────────────────────────────────────────────────────────────────
// Test 3: Arc weight is NOT reflected in YAWL XML — guards the missing feature
//
// build_yawl_xml and petri_net_to_yawl_xml accept only task name slices.
// There is no PetriNet-aware overload, so arc weights can never be emitted.
// This test asserts the current (broken) state so the regression is visible:
// it ASSERTS that weight="2" is absent, which proves the gap exists.
//
// When the fix is applied (a build_yawl_xml_from_net or weight-aware API),
// this test should be REPLACED by a test that asserts weight="2" IS present.
// ─────────────────────────────────────────────────────────────────────────────

#[test]
fn test_petri_net_to_yawl_xml_does_not_emit_arc_weight() {
    // build_yawl_xml takes (&str, &str, &[(&str, Vec<&str>)]) — no weight parameter.
    // A "weight=2" arc cannot be expressed; this test documents the gap.
    let xml = build_yawl_xml(
        "WeightTest",
        "source",
        &[
            ("source", vec!["sink"]),
            ("sink", vec!["OutputCondition"]),
        ],
    );

    // Gap documentation: weight attribute is absent from generated XML.
    // When this changes to assert!(xml.contains("weight=\"2\"")), the gap is closed.
    assert!(
        !xml.contains("weight="),
        "Expected no weight attribute in YAWL XML (gap: spec_builder has no PetriNet input). \
         Update this test when a weight-aware API is added."
    );
}

// ─────────────────────────────────────────────────────────────────────────────
// Test 4: check_conformance returns Ok(ConformanceResponse) on happy HTTP path
//
// Uses mockito to serve POST /api/process-mining/conformance locally.
// check_conformance is a synchronous function (it creates its own tokio Runtime)
// so this is a plain #[test], not #[tokio::test].
// ─────────────────────────────────────────────────────────────────────────────

#[test]
fn test_conformance_check_with_mock_server() {
    let mut server = mockito::Server::new();

    let _mock = server
        .mock("POST", "/api/process-mining/conformance")
        .with_status(200)
        .with_header("content-type", "application/json")
        .with_body(r#"{"fitness":0.87,"violations":[],"is_sound":true}"#)
        .create();

    // Redirect client to mockito's local address
    std::env::set_var("YAWLV6_URL", server.url());

    let client = YawlClient::new();
    let spec_xml = petri_net_to_yawl_xml(&["register", "approve", "pay"]);
    let result = client.check_conformance(&spec_xml, b"{}");

    let response = result.expect("check_conformance should return Ok on happy path");
    assert!(
        (response.fitness - 0.87).abs() < 0.001,
        "fitness should be 0.87, got {}",
        response.fitness
    );
    assert!(response.is_sound, "is_sound should be true");
    assert!(response.violations.is_empty(), "violations should be empty");
}
