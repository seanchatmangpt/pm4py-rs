      <date key="time:timestamp" value="2024-01-02T12:00:00.000Z"/>
    </event>
  </trace>
  <!-- Trace 3: Cancelled after inventory reserved -->
  <trace>
    <string key="concept:name" value="order_003"/>
    <event>
      <string key="concept:name" value="order_created"/>
      <date key="time:timestamp" value="2024-01-03T10:00:00.000Z"/>
    </event>
    <event>
      <string key="concept:name" value="payment_processed"/>
