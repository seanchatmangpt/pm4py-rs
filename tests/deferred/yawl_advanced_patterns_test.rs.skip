    // ═══════════════════════════════════════════════════════════════════════════════
    // AP6: STRUCTURED LOOP — Explicit loop construct with exit conditions
    // ═══════════════════════════════════════════════════════════════════════════════
    //
    // Pattern: Activity executed repeatedly until exit condition satisfied
    // Real-world: Retry logic, iterative validation, quality checks
    // Example: Document review → (validate) → [pass] OR [reject, loop back]
    //
    // Traces:
    // - Some loop once (first iteration passes)
    // - Some loop multiple times (multiple rejections)
    // - Finally exits when condition met

    fn create_structured_loop_log() -> String {
        let test_data_dir = get_test_data_dir();
        ensure_test_data_dir();

        let log_path = format!("{}/structured_loop_ap6.xes", test_data_dir);

        let xes_content = r#"<?xml version="1.0" encoding="UTF-8"?>
