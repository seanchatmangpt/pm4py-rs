    <event>
      <string key="concept:name" value="project_completed"/>
      <date key="time:timestamp" value="2024-01-10T21:00:00.000Z"/>
    </event>
  </trace>
</log>"#;

        fs::write(&log_path, xes_content).expect("Failed to write AP7 log");
        log_path
    }

    // ═══════════════════════════════════════════════════════════════════════════════
    // TEST CASES
    // ═══════════════════════════════════════════════════════════════════════════════

    // AP1: Implicit Choice
    // Test: Generate log with implicit choice, verify pattern discovered
    #[test]
    fn test_ap1_implicit_choice_log_generation() {
        let log_path = create_implicit_choice_log();
        assert!(Path::new(&log_path).exists(), "AP1 log file not created");

        let content = fs::read_to_string(&log_path)
            .expect("Failed to read AP1 log");
        assert!(content.contains("path_a"), "AP1 log missing path_a");
        assert!(content.contains("path_b"), "AP1 log missing path_b");
        assert!(content.contains("route_expert1"), "AP1 log missing expert1 routing");
        assert!(content.contains("route_expert2"), "AP1 log missing expert2 routing");
    }

    #[test]
    fn test_ap1_implicit_choice_non_determinism() {
        let log_path = create_implicit_choice_log();
        let content = fs::read_to_string(&log_path)
            .expect("Failed to read AP1 log");

        // Verify multiple traces with different paths exist
        let path_a_count = content.matches("path_a").count();
        let path_b_count = content.matches("path_b").count();

        assert!(path_a_count > 0, "AP1: No path_a traces found");
        assert!(path_b_count > 0, "AP1: No path_b traces found");
        assert_ne!(path_a_count, path_b_count, "AP1: Should have different counts");
    }

    #[test]
    fn test_ap1_implicit_choice_edge_case_all_same_path() {
        let log_path = create_implicit_choice_log();
        let content = fs::read_to_string(&log_path)
            .expect("Failed to read AP1 log");

        // Verify traces maintain consistency within their path
        let traces: Vec<&str> = content.split("<trace>").collect();
        assert!(traces.len() > 1, "AP1: Log should contain multiple traces");

        for trace in &traces[1..] {
            if trace.contains("path_a") {
                assert!(trace.contains("route_expert1"),
                    "AP1: path_a must route to expert1");
            } else if trace.contains("path_b") {
                assert!(trace.contains("route_expert2"),
                    "AP1: path_b must route to expert2");
            }
        }
    }

    // AP2: Deferred Choice
    // Test: Parallel activities execute, then choice based on outcomes
    #[test]
    fn test_ap2_deferred_choice_log_generation() {
        let log_path = create_deferred_choice_log();
        assert!(Path::new(&log_path).exists(), "AP2 log file not created");

        let content = fs::read_to_string(&log_path)
            .expect("Failed to read AP2 log");
        assert!(content.contains("validate_inventory"), "AP2: Missing inventory validation");
        assert!(content.contains("check_credit"), "AP2: Missing credit check");
        assert!(content.contains("path_approved"), "AP2: Missing approved path");
        assert!(content.contains("path_review"), "AP2: Missing review path");
    }

    #[test]
    fn test_ap2_deferred_choice_parallel_then_decide() {
        let log_path = create_deferred_choice_log();
        let content = fs::read_to_string(&log_path)
            .expect("Failed to read AP2 log");

        // Verify parallel activities occur before decision point
        let traces: Vec<&str> = content.split("<trace>").collect();
        for trace in &traces[1..] {
            // Find when validation occurs relative to check_credit
            let has_inventory = trace.contains("validate_inventory");
            let has_credit = trace.contains("check_credit");
            let has_path_decision = trace.contains("path_approved") ||
                                   trace.contains("path_review");

            if has_inventory && has_credit {
                assert!(has_path_decision,
                    "AP2: Decision point must follow parallel activities");
            }
        }
    }

    #[test]
    fn test_ap2_deferred_choice_decision_patterns() {
        let log_path = create_deferred_choice_log();
        let content = fs::read_to_string(&log_path)
            .expect("Failed to read AP2 log");

        let approved_count = content.matches("path_approved").count();
        let review_count = content.matches("path_review").count();

        assert!(approved_count > 0, "AP2: Should have approved paths");
        assert!(review_count > 0, "AP2: Should have review paths");
    }

    // AP3: Blocking Choice
    // Test: Process waits for external event before choice
    #[test]
    fn test_ap3_blocking_choice_log_generation() {
        let log_path = create_blocking_choice_log();
        assert!(Path::new(&log_path).exists(), "AP3 log file not created");

        let content = fs::read_to_string(&log_path)
            .expect("Failed to read AP3 log");
        assert!(content.contains("wait_for_appraisal"), "AP3: Missing wait activity");
        assert!(content.contains("appraisal_result_event"), "AP3: Missing trigger event");
        assert!(content.contains("approved"), "AP3: Missing approved path");
        assert!(content.contains("rejected"), "AP3: Missing rejected path");
    }

    #[test]
    fn test_ap3_blocking_choice_wait_point() {
        let log_path = create_blocking_choice_log();
        let content = fs::read_to_string(&log_path)
            .expect("Failed to read AP3 log");

        // Verify wait point exists before decision
        let traces: Vec<&str> = content.split("<trace>").collect();
        for trace in &traces[1..] {
            if trace.contains("wait_for_appraisal") {
                assert!(trace.contains("appraisal_result_event"),
                    "AP3: Wait must be followed by appraisal result");
            }
        }
    }

    #[test]
    fn test_ap3_blocking_choice_time_gap() {
        let log_path = create_blocking_choice_log();
        let content = fs::read_to_string(&log_path)
            .expect("Failed to read AP3 log");

        // Verify significant time gap between wait and decision (showing blocking)
        let traces: Vec<&str> = content.split("<trace>").collect();
        for trace in &traces[1..] {
            if let Some(wait_idx) = trace.find("wait_for_appraisal") {
                if let Some(result_idx) = trace.find("appraisal_result_event") {
                    assert!(result_idx > wait_idx,
                        "AP3: Result event must follow wait");
                    // Check for time difference in timestamps (observable blocking)
                }
            }
        }
    }

    // AP4: Cancellation
    // Test: Process can be cancelled with cleanup
    #[test]
    fn test_ap4_cancellation_log_generation() {
        let log_path = create_cancellation_log();
        assert!(Path::new(&log_path).exists(), "AP4 log file not created");

        let content = fs::read_to_string(&log_path)
            .expect("Failed to read AP4 log");
        assert!(content.contains("cancellation_requested"), "AP4: Missing cancellation event");
        assert!(content.contains("payment_refunded"), "AP4: Missing cleanup activity");
        assert!(content.contains("order_cancelled"), "AP4: Missing final state");
    }

    #[test]
    fn test_ap4_cancellation_happy_path_exists() {
        let log_path = create_cancellation_log();
        let content = fs::read_to_string(&log_path)
            .expect("Failed to read AP4 log");

        // Verify some traces complete normally
        let completed_count = content.matches("order_completed").count();
        assert!(completed_count > 0, "AP4: Should have some completed orders");
    }

    #[test]
    fn test_ap4_cancellation_cleanup_sequence() {
        let log_path = create_cancellation_log();
        let content = fs::read_to_string(&log_path)
            .expect("Failed to read AP4 log");

        // Verify cancellation leads to cleanup
        let traces: Vec<&str> = content.split("<trace>").collect();
        for trace in &traces[1..] {
            if trace.contains("cancellation_requested") {
                assert!(trace.contains("payment_refunded"),
                    "AP4: Cancellation must trigger refund cleanup");
                assert!(trace.contains("order_cancelled"),
                    "AP4: Cancellation must reach final state");
                // Verify cleanup happens after cancellation
                if let Some(cancel_idx) = trace.find("cancellation_requested") {
                    if let Some(refund_idx) = trace.find("payment_refunded") {
                        assert!(refund_idx > cancel_idx,
                            "AP4: Refund must occur after cancellation");
                    }
                }
            }
        }
    }

    // AP5: Cancellation/Region
    // Test: Entire region cancelled atomically
    #[test]
    fn test_ap5_cancellation_region_log_generation() {
        let log_path = create_cancellation_region_log();
        assert!(Path::new(&log_path).exists(), "AP5 log file not created");

        let content = fs::read_to_string(&log_path)
            .expect("Failed to read AP5 log");
        assert!(content.contains("escalation_triggered"), "AP5: Missing escalation trigger");
        assert!(content.contains("region_cancelled"), "AP5: Missing region cancellation");
        assert!(content.contains("escalation_handling"), "AP5: Missing escalation handling");
    }

    #[test]
    fn test_ap5_cancellation_region_atomic_behavior() {
        let log_path = create_cancellation_region_log();
        let content = fs::read_to_string(&log_path)
            .expect("Failed to read AP5 log");

        // Verify escalation cancels the entire region
        let traces: Vec<&str> = content.split("<trace>").collect();
        for trace in &traces[1..] {
            if trace.contains("escalation_triggered") {
                assert!(trace.contains("region_cancelled"),
                    "AP5: Escalation must cancel region");
                // Verify no activities complete from within the region
                let after_escalation = trace.split("escalation_triggered")
                    .nth(1)
                    .unwrap_or("");
                assert!(!after_escalation.contains("parallel_region_end"),
                    "AP5: Region should not complete normally after escalation");
            }
        }
    }

    #[test]
    fn test_ap5_cancellation_region_normal_path_exists() {
        let log_path = create_cancellation_region_log();
        let content = fs::read_to_string(&log_path)
            .expect("Failed to read AP5 log");

        // Verify normal flow without escalation exists
        let normal_count = content.matches("claim_approved").count();
        assert!(normal_count > 0, "AP5: Should have normal (non-escalated) paths");
    }

    // AP6: Structured Loop
    // Test: Loop executes until condition satisfied
    #[test]
    fn test_ap6_structured_loop_log_generation() {
        let log_path = create_structured_loop_log();
        assert!(Path::new(&log_path).exists(), "AP6 log file not created");

        let content = fs::read_to_string(&log_path)
            .expect("Failed to read AP6 log");
        assert!(content.contains("loop_iteration"), "AP6: Missing loop iteration");
        assert!(content.contains("validate_document"), "AP6: Missing validation activity");
        assert!(content.contains("validation_pass"), "AP6: Missing pass condition");
        assert!(content.contains("validation_fail"), "AP6: Missing fail condition");
    }

    #[test]
    fn test_ap6_structured_loop_multiple_iterations() {
        let log_path = create_structured_loop_log();
        let content = fs::read_to_string(&log_path)
            .expect("Failed to read AP6 log");

        // Verify traces with multiple iterations exist
        let iteration_count = content.matches("loop_iteration").count();
        assert!(iteration_count > 3, "AP6: Should have multiple iterations across traces");

        // Verify some traces loop multiple times
        let traces: Vec<&str> = content.split("<trace>").collect();
        let mut multi_iteration_found = false;
        for trace in &traces[1..] {
            let iterations = trace.matches("loop_iteration").count();
            if iterations > 1 {
                multi_iteration_found = true;
                break;
            }
        }
        assert!(multi_iteration_found, "AP6: Should have traces with multiple iterations");
    }

    #[test]
    fn test_ap6_structured_loop_exit_condition() {
        let log_path = create_structured_loop_log();
        let content = fs::read_to_string(&log_path)
            .expect("Failed to read AP6 log");

        // Verify loop exit always follows successful validation
        let traces: Vec<&str> = content.split("<trace>").collect();
        for trace in &traces[1..] {
            if trace.contains("loop_exit") {
                // Verify validation_pass occurs before loop_exit
                if let Some(exit_idx) = trace.find("loop_exit") {
                    let before_exit = &trace[..exit_idx];
                    assert!(before_exit.contains("validation_pass"),
                        "AP6: Loop exit must follow successful validation");
                }
            }
        }
    }

    // AP7: Generic Synchronization
    // Test: Complex multi-way synchronization
    #[test]
    fn test_ap7_generic_synchronization_log_generation() {
        let log_path = create_generic_synchronization_log();
        assert!(Path::new(&log_path).exists(), "AP7 log file not created");

        let content = fs::read_to_string(&log_path)
            .expect("Failed to read AP7 log");
        assert!(content.contains("design_phase_start"), "AP7: Missing design phase");
        assert!(content.contains("engineering_phase_start"), "AP7: Missing engineering phase");
        assert!(content.contains("marketing_phase_start"), "AP7: Missing marketing phase");
        assert!(content.contains("sync_point_1"), "AP7: Missing first sync point");
        assert!(content.contains("sync_point_2"), "AP7: Missing second sync point");
    }

    #[test]
    fn test_ap7_generic_synchronization_parallel_execution() {
        let log_path = create_generic_synchronization_log();
        let content = fs::read_to_string(&log_path)
            .expect("Failed to read AP7 log");

        // Verify all parallel phases execute
        let design_count = content.matches("design_phase_start").count();
        let engineering_count = content.matches("engineering_phase_start").count();
        let marketing_count = content.matches("marketing_phase_start").count();

        assert!(design_count > 0, "AP7: Design phase should execute");
        assert!(engineering_count > 0, "AP7: Engineering phase should execute");
        assert!(marketing_count > 0, "AP7: Marketing phase should execute");
    }

    #[test]
    fn test_ap7_generic_synchronization_dependencies() {
        let log_path = create_generic_synchronization_log();
        let content = fs::read_to_string(&log_path)
            .expect("Failed to read AP7 log");

        // Verify engineering waits for design (dependency)
        let traces: Vec<&str> = content.split("<trace>").collect();
        for trace in &traces[1..] {
            if trace.contains("engineering_phase_start") {
                // Verify design finished before engineering started
                if let Some(eng_idx) = trace.find("engineering_phase_start") {
                    let before_eng = &trace[..eng_idx];
                    assert!(before_eng.contains("design_phase_end"),
                        "AP7: Engineering must wait for design");
                }
            }
        }
    }

    #[test]
    fn test_ap7_generic_synchronization_multiple_sync_points() {
        let log_path = create_generic_synchronization_log();
        let content = fs::read_to_string(&log_path)
            .expect("Failed to read AP7 log");

        // Verify multiple synchronization points exist
        let sync1_count = content.matches("sync_point_1").count();
        let sync2_count = content.matches("sync_point_2").count();

        assert!(sync1_count > 0, "AP7: First sync point should exist");
        assert!(sync2_count > 0, "AP7: Second sync point should exist");

        // Verify sync points maintain order
        let traces: Vec<&str> = content.split("<trace>").collect();
        for trace in &traces[1..] {
            if let Some(sync1_idx) = trace.find("sync_point_1") {
                if let Some(sync2_idx) = trace.find("sync_point_2") {
                    assert!(sync2_idx > sync1_idx,
                        "AP7: sync_point_2 must follow sync_point_1");
                }
            }
        }
    }

    // ═══════════════════════════════════════════════════════════════════════════════
    // FORMAL VERIFICATION TESTS (Soundness Properties)
    // ═══════════════════════════════════════════════════════════════════════════════

    #[test]
    fn test_all_patterns_proper_termination() {
        // Verify all traces terminate properly (reach final state)
        let patterns = vec![
            ("AP1", create_implicit_choice_log()),
            ("AP2", create_deferred_choice_log()),
            ("AP3", create_blocking_choice_log()),
            ("AP4", create_cancellation_log()),
            ("AP5", create_cancellation_region_log()),
            ("AP6", create_structured_loop_log()),
            ("AP7", create_generic_synchronization_log()),
        ];

        for (name, log_path) in patterns {
            let content = fs::read_to_string(&log_path)
                .expect(&format!("Failed to read {} log", name));

            let traces: Vec<&str> = content.split("<trace>").collect();
            assert!(traces.len() > 1, "{}: Log should contain traces", name);

            // Verify each trace has final activity
            for trace in &traces[1..] {
                assert!(!trace.trim().is_empty(), "{}: Trace should not be empty", name);
            }
        }
    }

    #[test]
    fn test_all_patterns_no_infinite_loops() {
        // Verify patterns don't exhibit infinite loops in traces
        let patterns = vec![
            ("AP1", create_implicit_choice_log()),
            ("AP2", create_deferred_choice_log()),
            ("AP3", create_blocking_choice_log()),
            ("AP4", create_cancellation_log()),
            ("AP5", create_cancellation_region_log()),
            ("AP6", create_structured_loop_log()),
            ("AP7", create_generic_synchronization_log()),
        ];

        for (name, log_path) in patterns {
            let content = fs::read_to_string(&log_path)
                .expect(&format!("Failed to read {} log", name));

            let traces: Vec<&str> = content.split("<trace>").collect();
            for trace in &traces[1..] {
                // Count events in trace (should be reasonable)
                let event_count = trace.matches("<event>").count();
                assert!(event_count > 0 && event_count < 100,
                    "{}: Trace event count {} indicates possible infinite loop",
                    name, event_count);
            }
        }
    }

    #[test]
    fn test_all_patterns_liveness() {
        // Verify at least one trace completes successfully per pattern
        let patterns = vec![
            ("AP1", create_implicit_choice_log()),
            ("AP2", create_deferred_choice_log()),
            ("AP3", create_blocking_choice_log()),
            ("AP4", create_cancellation_log()),
            ("AP5", create_cancellation_region_log()),
            ("AP6", create_structured_loop_log()),
            ("AP7", create_generic_synchronization_log()),
        ];

        for (name, log_path) in patterns {
            let content = fs::read_to_string(&log_path)
                .expect(&format!("Failed to read {} log", name));

            // Verify log contains proper traces
            assert!(content.contains("<trace>"), "{}: No traces found", name);
            assert!(content.contains("</trace>"), "{}: Malformed trace", name);
        }
    }
}
