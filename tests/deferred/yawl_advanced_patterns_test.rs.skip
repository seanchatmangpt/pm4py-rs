  </trace>
  <!-- Trace 3: Both succeed → path_approved -->
  <trace>
    <string key="concept:name" value="order_003"/>
    <event>
      <string key="concept:name" value="order_received"/>
      <date key="time:timestamp" value="2024-01-03T10:00:00.000Z"/>
    </event>
    <event>
      <string key="concept:name" value="validate_inventory"/>
