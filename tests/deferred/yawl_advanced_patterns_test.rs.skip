    </event>
  </trace>
  <!-- Trace 3: Wait for appraisal → rejected -->
  <trace>
    <string key="concept:name" value="loan_003"/>
    <event>
      <string key="concept:name" value="application_submitted"/>
      <date key="time:timestamp" value="2024-01-03T10:00:00.000Z"/>
