    // ═══════════════════════════════════════════════════════════════════════════════
    // AP4: CANCELLATION — Abort path without completing all activities
    // ═══════════════════════════════════════════════════════════════════════════════
    //
    // Pattern: Process execution halts; pending activities are cancelled
    // Real-world: Customer cancels order → cleanup but not full workflow
    // Example: Order processing → [can be cancelled at any stage] → cleanup
    //
    // Traces:
    // - Some complete fully (happy path)
    // - Some are cancelled mid-way with cleanup
    // - Cancelled traces show cancellation event + cleanup

    fn create_cancellation_log() -> String {
        let test_data_dir = get_test_data_dir();
        ensure_test_data_dir();

        let log_path = format!("{}/cancellation_ap4.xes", test_data_dir);

        let xes_content = r#"<?xml version="1.0" encoding="UTF-8"?>
<log xes.version="1.0" xes.features="nested-attributes" xmlns="http://www.xes-standard.org/">
  <extension name="Concept" prefix="concept" uri="http://www.xes-standard.org/concept.xesext"/>
  <extension name="Time" prefix="time" uri="http://www.xes-standard.org/time.xesext"/>
  <global scope="trace">
    <string key="concept:name" value="case name"/>
  </global>
  <global scope="event">
    <string key="concept:name" value="activity name"/>
    <date key="time:timestamp" value="timestamp"/>
  </global>
  <!-- Trace 1: Complete happy path -->
  <trace>
    <string key="concept:name" value="order_001"/>
    <event>
      <string key="concept:name" value="order_created"/>
      <date key="time:timestamp" value="2024-01-01T10:00:00.000Z"/>
    </event>
    <event>
      <string key="concept:name" value="payment_processed"/>
      <date key="time:timestamp" value="2024-01-01T10:05:00.000Z"/>
