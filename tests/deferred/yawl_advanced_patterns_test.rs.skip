    // ═══════════════════════════════════════════════════════════════════════════════
    // AP5: CANCELLATION/REGION — Cancel entire sub-region atomically
    // ═══════════════════════════════════════════════════════════════════════════════
    //
    // Pattern: When condition triggered, entire sub-region is cancelled atomically
    // Real-world: Process escalation triggers cancellation of all pending tasks in region
    // Example: Customer escalates → (cancel all parallel checks) → escalation handling
    //
    // Traces show:
    // - Normal flow: parallel activities execute
    // - Escalation flow: all parallel tasks cancelled, escalation process starts

    fn create_cancellation_region_log() -> String {
        let test_data_dir = get_test_data_dir();
        ensure_test_data_dir();

