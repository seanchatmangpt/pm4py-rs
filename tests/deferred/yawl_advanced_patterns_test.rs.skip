    </event>
  </trace>
  <!-- Trace 2: Wait for appraisal → approved -->
  <trace>
    <string key="concept:name" value="loan_002"/>
    <event>
      <string key="concept:name" value="application_submitted"/>
      <date key="time:timestamp" value="2024-01-02T10:00:00.000Z"/>
