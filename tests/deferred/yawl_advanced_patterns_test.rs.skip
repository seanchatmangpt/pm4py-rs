      <date key="time:timestamp" value="2024-01-03T10:20:00.000Z"/>
    </event>
    <event>
      <string key="concept:name" value="inventory_released"/>
      <date key="time:timestamp" value="2024-01-03T10:25:00.000Z"/>
    </event>
    <event>
      <string key="concept:name" value="payment_refunded"/>
      <date key="time:timestamp" value="2024-01-03T10:30:00.000Z"/>
    </event>
    <event>
      <string key="concept:name" value="order_cancelled"/>
      <date key="time:timestamp" value="2024-01-03T10:35:00.000Z"/>
    </event>
  </trace>
  <!-- Trace 4: Cancelled after payment -->
  <trace>
