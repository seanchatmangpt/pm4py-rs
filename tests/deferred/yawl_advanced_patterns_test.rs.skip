    // ═══════════════════════════════════════════════════════════════════════════════
    // AP3: BLOCKING CHOICE — Choice blocks until guard condition is enabled
    // ═══════════════════════════════════════════════════════════════════════════════
    //
    // Pattern: Choice point waits until a specific event/condition enables one branch
    // Real-world: Process waits for external trigger before proceeding
    // Example: Loan application → (wait for appraisal) → approved OR rejected
    //
    // Traces:
    // - Activities show wait, then decision based on external event
    // - Appraisal result triggers one of two paths
    // - Non-blocking traces would execute both in parallel

    fn create_blocking_choice_log() -> String {
        let test_data_dir = get_test_data_dir();
        ensure_test_data_dir();

        let log_path = format!("{}/blocking_choice_ap3.xes", test_data_dir);

        let xes_content = r#"<?xml version="1.0" encoding="UTF-8"?>
<log xes.version="1.0" xes.features="nested-attributes" xmlns="http://www.xes-standard.org/">
  <extension name="Concept" prefix="concept" uri="http://www.xes-standard.org/concept.xesext"/>
  <extension name="Time" prefix="time" uri="http://www.xes-standard.org/time.xesext"/>
  <global scope="trace">
    <string key="concept:name" value="case name"/>
  </global>
  <global scope="event">
    <string key="concept:name" value="activity name"/>
    <date key="time:timestamp" value="timestamp"/>
  </global>
  <!-- Trace 1: Wait for appraisal → approved -->
  <trace>
    <string key="concept:name" value="loan_001"/>
    <event>
