    // ═══════════════════════════════════════════════════════════════════════════════
    // AP2: DEFERRED CHOICE — Decision deferred until runtime observation
    // ═══════════════════════════════════════════════════════════════════════════════
    //
    // Pattern: Choice is not pre-determined; branches execute and choice emerges later
    // Real-world: Process starts, work begins, later observation determines actual path
    // Example: Order → (parallel) validate_inventory AND check_credit → choice based on results
    //
    // Traces:
    // - 3 traces: validate_inventory succeeds → proceed path_approved
    // - 2 traces: check_credit fails → redirect path_review
    // - Choice point is after parallel execution

    fn create_deferred_choice_log() -> String {
        let test_data_dir = get_test_data_dir();
        ensure_test_data_dir();

        let log_path = format!("{}/deferred_choice_ap2.xes", test_data_dir);

        let xes_content = r#"<?xml version="1.0" encoding="UTF-8"?>
