#[test]
fn test_get_resource_workload_basic() {
    let log = create_resource_log();
    let workloads = get_resource_workload(&log);

    assert!(!workloads.is_empty());

    // Clerk should have the most events
    let clerk = workloads.iter().find(|w| w.resource == "clerk");
    assert!(clerk.is_some());
    assert!(clerk.unwrap().event_count > 0);

    // Workload percentages should sum to 100%
    let total_percentage: f64 = workloads.iter().map(|w| w.workload_percentage).sum();
    assert!((total_percentage - 100.0).abs() < 0.1);
}

#[test]
fn test_get_resource_workload_ordering() {
    let log = create_resource_log();
    let workloads = get_resource_workload(&log);

    // Should be sorted by event count descending
    for i in 0..(workloads.len() - 1) {
        assert!(workloads[i].event_count >= workloads[i + 1].event_count);
    }
}

#[test]
fn test_get_resource_workload_empty_log() {
    let log = create_empty_log();
    let workloads = get_resource_workload(&log);

    assert!(workloads.is_empty());
}

#[test]
fn test_get_resource_workload_no_resources() {
    let log = create_simple_log();
    let mut log_no_resources = EventLog::new();

    for trace in &log.traces {
        let mut new_trace = Trace::new(trace.id.clone());
        for event in &trace.events {
            let mut new_event = Event::new(&event.activity, event.timestamp);
            if let Some(attrs) = &event.attributes {
                for (k, v) in attrs {
                    new_event = new_event.with_attribute(k, v);
                }
            }
            new_trace.add_event(new_event);
        }
        log_no_resources.add_trace(new_trace);
    }

    let workloads = get_resource_workload(&log_no_resources);
    assert!(workloads.is_empty());
}

#[test]
fn test_get_resource_availability_basic() {
    let log = create_resource_log();
    let availability = get_resource_availability(&log);

    assert!(!availability.is_empty());

    for resource in &availability {
        assert!(resource.first_activity_time <= resource.last_activity_time);
        assert!(resource.active_duration_seconds >= 0.0);
        assert!(resource.num_activities > 0);
    }
}

#[test]
fn test_get_resource_collaboration_basic() {
    let log = create_resource_log();
    let collaborations = get_resource_collaboration(&log);

    // Should find clerk-senior collaboration
    let clerk_senior = collaborations.iter().find(|c| {
        (c.resource1 == "clerk" && c.resource2 == "senior")
            || (c.resource1 == "senior" && c.resource2 == "clerk")
    });

    assert!(clerk_senior.is_some() || collaborations.is_empty()); // May be empty if no collaboration
}

#[test]
fn test_get_resource_collaboration_percentage() {
    let log = create_resource_log();
    let collaborations = get_resource_collaboration(&log);

    for collab in &collaborations {
        assert!(collab.collaboration_percentage >= 0.0);
        assert!(collab.collaboration_percentage <= 100.0);
    }
}

#[test]
fn test_get_resource_efficiency_basic() {
    let log = create_resource_log();
    let efficiencies = get_resource_efficiency(&log);

    assert!(!efficiencies.is_empty());

    for eff in &efficiencies {
        assert!(eff.efficiency_score >= 0.0);
        assert!(eff.efficiency_score <= 1.0);
        assert!(eff.min_duration <= eff.max_duration);
    }
}

