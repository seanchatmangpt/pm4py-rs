#[test]
fn test_calculate_activity_transition_times_basic() {
    let log = create_simple_log();
    let transitions = calculate_activity_transition_times(&log);

    assert!(!transitions.is_empty());

    // Should have transitions like register->examine, examine->decide
    let register_to_examine = transitions
        .iter()
        .find(|t| t.from_activity == "register" && t.to_activity == "examine");
    assert!(register_to_examine.is_some());

    let trans = register_to_examine.unwrap();
    assert!(trans.min_time_seconds <= trans.avg_time_seconds);
    assert!(trans.avg_time_seconds <= trans.max_time_seconds);
}

#[test]
fn test_calculate_activity_transition_times_ordering() {
    let log = create_simple_log();
    let transitions = calculate_activity_transition_times(&log);

    // Should be sorted by avg time descending
    for i in 0..(transitions.len() - 1) {
        assert!(transitions[i].avg_time_seconds >= transitions[i + 1].avg_time_seconds);
    }
}

#[test]
fn test_check_sla_compliance_basic() {
    let log = create_simple_log();
    let compliance = check_sla_compliance(&log, Some(7200.0)); // 2 hours SLA

    assert_eq!(compliance.len(), 2);

    for comp in &compliance {
        assert!(comp.total_duration_seconds >= 0.0);
        assert_eq!(comp.sla_threshold_seconds, 7200.0);
    }
}

#[test]
fn test_check_sla_compliance_default_24h() {
    let log = create_simple_log();
    let compliance = check_sla_compliance(&log, None); // Default 24 hours

    assert!(!compliance.is_empty());

    for comp in &compliance {
        assert_eq!(comp.sla_threshold_seconds, 86400.0);
    }
}

#[test]
fn test_check_sla_compliance_variance() {
    let log = create_simple_log();
    let compliance = check_sla_compliance(&log, Some(3600.0)); // 1 hour SLA

    for comp in &compliance {
        // Some should be compliant (variance negative), some not
        if comp.total_duration_seconds <= 3600.0 {
            assert!(comp.is_compliant);
        } else {
            assert!(!comp.is_compliant);
        }
    }
}

#[test]
fn test_get_peak_hours_analysis() {
    let log = create_time_log();
    let peak_hours = get_peak_hours_analysis(&log);

    // Should have 24 hours
    assert_eq!(peak_hours.len(), 24);

    // Should be sorted by event count descending
    for i in 0..(peak_hours.len() - 1) {
        assert!(peak_hours[i].event_count >= peak_hours[i + 1].event_count);
    }

    // Percentages should sum to 100%
    let total_percentage: f64 = peak_hours.iter().map(|h| h.percentage).sum();
    assert!((total_percentage - 100.0).abs() < 0.1);
}

#[test]
fn test_get_workload_distribution_by_day() {
    let log = create_time_log();
    let workloads = get_workload_distribution_by_day(&log);

    // Should have 7 days
    assert_eq!(workloads.len(), 7);

    // Percentages should sum to 100%
    let total_percentage: f64 = workloads.iter().map(|w| w.percentage).sum();
    assert!((total_percentage - 100.0).abs() < 0.1);
}

