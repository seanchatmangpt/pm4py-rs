#[test]
fn test_detect_frequency_anomalies_empty_log() {
    let log = create_empty_log();
    let anomalies = detect_frequency_anomalies(&log, Some(2.0));

    assert!(anomalies.is_empty());
}

// ============================================================================
// PARITY TESTS WITH PYTHON PM4PY
// ============================================================================

#[test]
fn test_parity_attribute_statistics() {
    // Test that attribute statistics are consistent
    let log = create_simple_log();
    let frequencies = get_attribute_value_frequency(&log);

    // Check that all frequencies are counted correctly
    let total_count: usize = frequencies.iter().map(|f| f.frequency).sum();
    assert_eq!(total_count, log.num_events());

    // Check percentages sum to 100
    let total_percentage: f64 = frequencies.iter().map(|f| f.percentage).sum();
    assert!((total_percentage - 100.0).abs() < 0.1);
}

#[test]
fn test_parity_resource_metrics_consistency() {
    let log = create_resource_log();
    let workloads = get_resource_workload(&log);

    // Total events should match log
    let total_events: usize = workloads.iter().map(|w| w.event_count).sum();
    let expected_events = log
        .traces
        .iter()
        .flat_map(|t| &t.events)
        .filter(|e| e.resource.is_some())
        .count();
    assert_eq!(total_events, expected_events);
}

#[test]
fn test_parity_transition_times_consistency() {
    let log = create_simple_log();
    let transitions = calculate_activity_transition_times(&log);

    // Each transition should have consistent min/max/avg
    for trans in &transitions {
        assert!(trans.min_time_seconds <= trans.avg_time_seconds);
        assert!(trans.avg_time_seconds <= trans.max_time_seconds);
        assert!(trans.count > 0);
    }
}

#[test]
fn test_numeric_precision_activity_transitions() {
    let mut log = EventLog::new();
    let base = Utc::now();

    // Create traces with very precise timing
    for i in 0..10 {
        let mut trace = Trace::new(format!("case_{}", i));
        trace.add_event(Event::new(
            "A",
            base + Duration::milliseconds(i as i64 * 1000),
        ));
        trace.add_event(Event::new(
            "B",
            base + Duration::milliseconds(i as i64 * 1000 + 500),
        ));
        log.add_trace(trace);
    }

    let transitions = calculate_activity_transition_times(&log);

    // All transitions A->B should have duration 0.5 seconds
    let a_to_b = transitions
        .iter()
        .find(|t| t.from_activity == "A" && t.to_activity == "B");
    assert!(a_to_b.is_some());

    let trans = a_to_b.unwrap();
    assert!((trans.min_time_seconds - 0.5).abs() < 1e-9);
    assert!((trans.max_time_seconds - 0.5).abs() < 1e-9);
    assert!((trans.avg_time_seconds - 0.5).abs() < 1e-9);
}

#[test]
fn test_edge_case_single_event_trace() {
    let mut log = EventLog::new();
    let now = Utc::now();

    let mut trace = Trace::new("case_1");
    trace.add_event(Event::new("A", now).with_resource("clerk"));
    log.add_trace(trace);

    // Should handle single event trace gracefully
    let transitions = calculate_activity_transition_times(&log);
    assert!(transitions.is_empty()); // No transitions with single event

    let workload = get_resource_workload(&log);
    assert_eq!(workload.len(), 1);
    assert_eq!(workload[0].event_count, 1);
}

#[test]
fn test_edge_case_identical_timestamps() {
    let mut log = EventLog::new();
    let now = Utc::now();

    // Case where multiple events have same timestamp
    let mut trace = Trace::new("case_1");
    trace.add_event(Event::new("A", now).with_resource("clerk"));
    trace.add_event(Event::new("B", now).with_resource("senior")); // Same time
    trace.add_event(Event::new("C", now).with_resource("manager")); // Same time
    log.add_trace(trace);

    let transitions = calculate_activity_transition_times(&log);
    for trans in &transitions {
        assert!(trans.avg_time_seconds >= 0.0); // Should be 0 for same timestamp
    }
}

#[test]
fn test_comprehensive_workflow_analysis() {
    // Test a complete workflow with all statistics
    let log = create_resource_log();

    // Run all analysis functions
    let case_attrs = get_case_attributes(&log);
    let attr_freqs = get_attribute_value_frequency(&log);
    let workloads = get_resource_workload(&log);
    let availability = get_resource_availability(&log);
    let collaborations = get_resource_collaboration(&log);
    let transitions = calculate_activity_transition_times(&log);
    let sla = check_sla_compliance(&log, Some(7200.0));
    let complexity = calculate_case_complexity(&log);

    // All should complete without panic
    assert!(case_attrs.len() > 0 || case_attrs.is_empty());
    assert!(workloads.len() > 0);
    assert!(transitions.len() > 0);
    assert_eq!(sla.len(), log.traces.len());
    assert_eq!(complexity.len(), log.traces.len());
}
