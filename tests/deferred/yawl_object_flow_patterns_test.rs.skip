    #[test]
    fn test_of6_object_merging() {
        let log_path = create_object_merging_log();
        let log_content = fs::read_to_string(&log_path).expect("Failed to read log");

        let has_source = log_content.contains("source_object_id");
        let has_target = log_content.contains("target_object_id");
        let multiple_merges = log_content.matches("merge_shipments").count() >= 3;

        assert!(
            has_source && has_target && multiple_merges,
            "Multiple objects should merge into one"
        );

        fs::remove_file(&log_path).ok();
    }

    // ═══════════════════════════════════════════════════════════════════════════════
    // OF7: OBJECT COLLECTION — Objects collected into aggregates
    // ═══════════════════════════════════════════════════════════════════════════════

    fn create_object_collection_log() -> String {
        let test_data_dir = get_test_data_dir();
        ensure_test_data_dir();

        let log_path = format!("{}/object_collection_of7.xes", test_data_dir);

        let xes_content = r#"<?xml version="1.0" encoding="UTF-8"?>
<log xes.version="1.0" xes.features="nested-attributes" xmlns="http://www.xes-standard.org/">
