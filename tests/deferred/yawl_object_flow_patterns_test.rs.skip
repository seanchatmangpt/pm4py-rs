    #[test]
    fn test_of7_object_collection() {
        let log_path = create_object_collection_log();
        let log_content = fs::read_to_string(&log_path).expect("Failed to read log");

        let has_items = log_content.contains("item_");
        let has_collection = log_content.contains("collection_id");
        let collection_ops = log_content.matches("collect_items").count();

        assert!(
            has_items && has_collection && collection_ops >= 3,
            "Objects should be collected into aggregates"
        );

        fs::remove_file(&log_path).ok();
    }

    // ═══════════════════════════════════════════════════════════════════════════════
    // OF8: OBJECT DECOMPOSITION — Objects broken into sub-objects
    // ═══════════════════════════════════════════════════════════════════════════════

    fn create_object_decomposition_log() -> String {
        let test_data_dir = get_test_data_dir();
        ensure_test_data_dir();

        let log_path = format!("{}/object_decomposition_of8.xes", test_data_dir);

        let xes_content = r#"<?xml version="1.0" encoding="UTF-8"?>
<log xes.version="1.0" xes.features="nested-attributes" xmlns="http://www.xes-standard.org/">
  <extension name="Concept" prefix="concept" uri="http://www.xes-standard.org/concept.xesext"/>
  <extension name="Time" prefix="time" uri="http://www.xes-standard.org/time.xesext"/>
  <extension name="Object" prefix="obj" uri="http://www.xes-standard.org/object.xesext"/>
  <global scope="trace">
    <string key="concept:name" value="case id"/>
  </global>
  <global scope="event">
    <string key="concept:name" value="activity"/>
    <date key="time:timestamp" value="timestamp"/>
  </global>
  <trace>
    <string key="concept:name" value="decompose_001"/>
    <event>
      <string key="concept:name" value="decompose_object"/>
      <date key="time:timestamp" value="2024-01-01T09:00:00.000Z"/>
      <string key="obj:object_id" value="obj_001"/>
      <string key="obj:component_id" value="comp_001"/>
      <string key="obj:component_type" value="part"/>
    </event>
    <event>
      <string key="concept:name" value="decompose_object"/>
      <date key="time:timestamp" value="2024-01-01T09:05:00.000Z"/>
      <string key="obj:object_id" value="obj_001"/>
      <string key="obj:component_id" value="comp_002"/>
      <string key="obj:component_type" value="part"/>
    </event>
    <event>
      <string key="concept:name" value="decompose_object"/>
      <date key="time:timestamp" value="2024-01-01T09:10:00.000Z"/>
      <string key="obj:object_id" value="obj_001"/>
      <string key="obj:component_id" value="comp_003"/>
      <string key="obj:component_type" value="part"/>
    </event>
  </trace>
</log>"#;

        fs::write(&log_path, xes_content).expect("Failed to write XES log");
        log_path
    }

    #[test]
    fn test_of8_object_decomposition() {
        let log_path = create_object_decomposition_log();
        let log_content = fs::read_to_string(&log_path).expect("Failed to read log");

        let has_parent = log_content.contains("object_id") && log_content.contains("obj_001");
        let has_components = log_content.contains("comp_001") && log_content.contains("comp_002");

        assert!(
            has_parent && has_components,
            "Object should decompose into parts"
        );

        fs::remove_file(&log_path).ok();
    }

    // ═══════════════════════════════════════════════════════════════════════════════
    // SOUNDNESS VERIFICATION TESTS
    // ═══════════════════════════════════════════════════════════════════════════════

    #[test]
    fn test_all_object_patterns_lifecycle_soundness() {
        let patterns = vec![
            ("OF1", create_object_creation_log()),
            ("OF2", create_object_modification_log()),
            ("OF3", create_object_consumption_log()),
            ("OF4", create_object_state_transitions_log()),
            ("OF5", create_object_branching_log()),
            ("OF6", create_object_merging_log()),
            ("OF7", create_object_collection_log()),
            ("OF8", create_object_decomposition_log()),
        ];

        for (pattern_name, log_path) in patterns {
            let log_content = fs::read_to_string(&log_path).expect("Failed to read log");
            assert!(
                verify_object_lifecycle(&log_content),
                "{} should have proper object lifecycle",
                pattern_name
            );
            assert!(
                verify_state_transitions(&log_content),
                "{} should have valid state transitions",
                pattern_name
            );
            fs::remove_file(&log_path).ok();
        }
    }

    #[test]
    fn test_object_reference_integrity() {
        // Verify that all object references are valid
        let log_path = create_object_branching_log();
        let log_content = fs::read_to_string(&log_path).expect("Failed to read log");

        // Count parent and child references
        let parent_count = log_content.matches("parent_object_id").count();
        let child_count = log_content.matches("child_object_id").count();

        // Should have consistent references
        assert!(
            parent_count > 0 && child_count > 0,
            "Should have parent-child references"
        );

        fs::remove_file(&log_path).ok();
    }

    #[test]
    fn test_object_lifecycle_completeness() {
        // Verify all created objects are eventually processed
        let log_path = create_object_state_transitions_log();
        let log_content = fs::read_to_string(&log_path).expect("Failed to read log");

        // Should have creation and completion
        let has_creation = log_content.contains("created");
        let has_completion = log_content.contains("completed") || log_content.contains("archived");

        assert!(
            has_creation && has_completion,
            "Objects should have complete lifecycle"
        );

        fs::remove_file(&log_path).ok();
    }
}
