//! Advanced Statistics Tests with Python pm4py Parity Validation
//!
//! Tests production-grade accuracy (<1e-10 relative error) for:
//! - Case duration distribution (min, max, mean, median, stddev)
//! - Activity frequency analysis
//! - Variant frequency analysis
//! - Rework pattern identification
//! - Resource allocation metrics
//! - Performance indicators (throughput, bottlenecks)
//!
//! TDD Pattern: Failing test first, then implementation

use pm4py::log::{Event, EventLog, Trace};
use pm4py::statistics::{
    case_duration_distribution, case_duration_distribution_per_variant,
    get_activity_frequency, get_variant_frequency, identify_rework_patterns,
    get_rework_count_per_activity, get_resource_metrics, get_activity_throughput,
    get_case_throughput, get_bottleneck_activities, calculate_performance_indicators,
};
use chrono::{Utc, Duration};

// ============================================================================
// Test Data Builders
// ============================================================================

fn create_perfect_account_log() -> EventLog {
    let mut log = EventLog::new();
    let now = Utc::now();

    // 5 traces with same variant: register -> examine -> decide
    for i in 0..5 {
        let mut trace = Trace::new(format!("case_{}", i));
        trace.add_event(Event::new("register", now + Duration::hours(i as i64)));
        trace.add_event(Event::new("examine", now + Duration::hours(i as i64) + Duration::minutes(30)));
        trace.add_event(Event::new("decide", now + Duration::hours(i as i64) + Duration::hours(2)));
        log.add_trace(trace);
    }

    log
}

fn create_multi_variant_log() -> EventLog {
    let mut log = EventLog::new();
    let now = Utc::now();

    // Variant 1: A -> B -> C (3 traces)
    for i in 0..3 {
        let mut trace = Trace::new(format!("case_v1_{}", i));
        trace.add_event(Event::new("A", now + Duration::hours((i * 3) as i64)));
        trace.add_event(Event::new("B", now + Duration::hours((i * 3) as i64) + Duration::minutes(30)));
        trace.add_event(Event::new("C", now + Duration::hours((i * 3) as i64) + Duration::hours(1)));
        log.add_trace(trace);
    }

    // Variant 2: A -> D -> C (2 traces)
    for i in 0..2 {
        let mut trace = Trace::new(format!("case_v2_{}", i));
        trace.add_event(Event::new("A", now + Duration::hours((9 + i * 3) as i64)));
        trace.add_event(Event::new("D", now + Duration::hours((9 + i * 3) as i64) + Duration::minutes(45)));
        trace.add_event(Event::new("C", now + Duration::hours((9 + i * 3) as i64) + Duration::hours(2)));
        log.add_trace(trace);
    }

    log
}

fn create_rework_log() -> EventLog {
    let mut log = EventLog::new();
    let now = Utc::now();

    // Case 1: A -> B -> A (rework) -> C
    let mut trace1 = Trace::new("case_1");
    trace1.add_event(Event::new("A", now));
    trace1.add_event(Event::new("B", now + Duration::minutes(10)));
    trace1.add_event(Event::new("A", now + Duration::minutes(20)));  // Rework
    trace1.add_event(Event::new("C", now + Duration::minutes(30)));
    log.add_trace(trace1);

    // Case 2: A -> B -> C (no rework)
    let mut trace2 = Trace::new("case_2");
    trace2.add_event(Event::new("A", now + Duration::hours(1)));
    trace2.add_event(Event::new("B", now + Duration::hours(1) + Duration::minutes(10)));
    trace2.add_event(Event::new("C", now + Duration::hours(1) + Duration::minutes(20)));
    log.add_trace(trace2);

    // Case 3: A -> B -> B (rework) -> B (rework) -> C
    let mut trace3 = Trace::new("case_3");
    trace3.add_event(Event::new("A", now + Duration::hours(2)));
    trace3.add_event(Event::new("B", now + Duration::hours(2) + Duration::minutes(10)));
    trace3.add_event(Event::new("B", now + Duration::hours(2) + Duration::minutes(20)));  // Rework
    trace3.add_event(Event::new("B", now + Duration::hours(2) + Duration::minutes(30)));  // Rework
    trace3.add_event(Event::new("C", now + Duration::hours(2) + Duration::minutes(40)));
    log.add_trace(trace3);

    log
}

fn create_resource_log() -> EventLog {
    let mut log = EventLog::new();
    let now = Utc::now();

    // Case 1: clerk registers, senior examines, manager decides
    let mut trace1 = Trace::new("case_1");
    trace1.add_event(Event::new("register", now).with_resource("clerk"));
    trace1.add_event(Event::new("examine", now + Duration::minutes(30)).with_resource("senior"));
    trace1.add_event(Event::new("decide", now + Duration::hours(1)).with_resource("manager"));
    log.add_trace(trace1);

    // Case 2: clerk registers, senior examines, manager decides
    let mut trace2 = Trace::new("case_2");
    trace2.add_event(Event::new("register", now + Duration::hours(2)).with_resource("clerk"));
    trace2.add_event(Event::new("examine", now + Duration::hours(2) + Duration::minutes(30)).with_resource("senior"));
    trace2.add_event(Event::new("decide", now + Duration::hours(3)).with_resource("manager"));
    log.add_trace(trace2);

    // Case 3: clerk registers, senior examines, manager decides (clerk fast)
    let mut trace3 = Trace::new("case_3");
    trace3.add_event(Event::new("register", now + Duration::hours(4)).with_resource("clerk"));
    trace3.add_event(Event::new("examine", now + Duration::hours(4) + Duration::minutes(15)).with_resource("senior"));
    trace3.add_event(Event::new("decide", now + Duration::hours(5)).with_resource("manager"));
    log.add_trace(trace3);

    log
}

fn create_empty_log() -> EventLog {
    EventLog::new()
}

fn create_single_event_log() -> EventLog {
    let mut log = EventLog::new();
    let mut trace = Trace::new("case_1");
    trace.add_event(Event::new("A", Utc::now()));
    log.add_trace(trace);
    log
}

// ============================================================================
// Case Duration Distribution Tests
// ============================================================================

#[test]
fn test_case_duration_distribution_basic() {
    let log = create_perfect_account_log();
    let stats = case_duration_distribution(&log);

    // All cases have same duration: 30 min + 90 min = 120 min = 7200 seconds
    assert_eq!(stats.count, 5);
    assert!((stats.min_duration - 7200.0).abs() < 1e-6);
    assert!((stats.max_duration - 7200.0).abs() < 1e-6);
    assert!((stats.mean_duration - 7200.0).abs() < 1e-6);
    assert!((stats.median_duration - 7200.0).abs() < 1e-6);
    assert!(stats.stddev_duration < 1e-6);  // No variance
}

#[test]
fn test_case_duration_distribution_variance() {
    let mut log = EventLog::new();
    let now = Utc::now();

    // Case 1: 100 seconds
    let mut trace1 = Trace::new("case_1");
    trace1.add_event(Event::new("A", now));
    trace1.add_event(Event::new("B", now + Duration::seconds(100)));
    log.add_trace(trace1);

    // Case 2: 200 seconds
    let mut trace2 = Trace::new("case_2");
    trace2.add_event(Event::new("A", now + Duration::hours(1)));
    trace2.add_event(Event::new("B", now + Duration::hours(1) + Duration::seconds(200)));
    log.add_trace(trace2);

    // Case 3: 300 seconds
    let mut trace3 = Trace::new("case_3");
    trace3.add_event(Event::new("A", now + Duration::hours(2)));
    trace3.add_event(Event::new("B", now + Duration::hours(2) + Duration::seconds(300)));
    log.add_trace(trace3);

    let stats = case_duration_distribution(&log);

    assert_eq!(stats.count, 3);
    assert!((stats.min_duration - 100.0).abs() < 1e-6);
    assert!((stats.max_duration - 300.0).abs() < 1e-6);
    assert!((stats.mean_duration - 200.0).abs() < 1e-6);  // (100+200+300)/3
    assert!((stats.median_duration - 200.0).abs() < 1e-6);

    // Stddev = sqrt(((100-200)^2 + (200-200)^2 + (300-200)^2) / 3)
    //        = sqrt((10000 + 0 + 10000) / 3)
    //        = sqrt(6666.667) ≈ 81.65
    assert!((stats.stddev_duration - 81.65).abs() < 0.1);
}

#[test]
fn test_case_duration_distribution_empty_log() {
    let log = create_empty_log();
    let stats = case_duration_distribution(&log);

    assert_eq!(stats.count, 0);
    assert_eq!(stats.min_duration, 0.0);
    assert_eq!(stats.max_duration, 0.0);
    assert_eq!(stats.mean_duration, 0.0);
    assert_eq!(stats.median_duration, 0.0);
    assert_eq!(stats.stddev_duration, 0.0);
}

#[test]
fn test_case_duration_distribution_single_trace() {
    let log = create_single_event_log();
    let stats = case_duration_distribution(&log);

    // Single event trace has 0 duration
    assert_eq!(stats.count, 1);
    assert_eq!(stats.min_duration, 0.0);
    assert_eq!(stats.max_duration, 0.0);
    assert_eq!(stats.mean_duration, 0.0);
    assert_eq!(stats.median_duration, 0.0);
    assert_eq!(stats.stddev_duration, 0.0);
}

// ============================================================================
// Variant Duration Distribution Tests
// ============================================================================

#[test]
fn test_case_duration_per_variant_basic() {
    let log = create_multi_variant_log();
    let variant_stats = case_duration_distribution_per_variant(&log);

    assert_eq!(variant_stats.len(), 2);

    // First variant (A->B->C, 3 traces) should come first (higher count)
    assert_eq!(variant_stats[0].count, 3);
    assert_eq!(variant_stats[0].variant[0], "A");

    // Variant 1 duration: 30 min + 30 min = 60 min = 3600 seconds
    assert!((variant_stats[0].mean_duration - 3600.0).abs() < 1e-6);

    // Second variant (A->D->C, 2 traces)
    assert_eq!(variant_stats[1].count, 2);

    // Variant 2 duration: 45 min + 75 min = 120 min = 7200 seconds
    assert!((variant_stats[1].mean_duration - 7200.0).abs() < 1e-6);
}

#[test]
fn test_case_duration_per_variant_empty() {
    let log = create_empty_log();
    let variant_stats = case_duration_distribution_per_variant(&log);

    assert!(variant_stats.is_empty());
}

// ============================================================================
// Activity Frequency Tests
// ============================================================================

#[test]
fn test_activity_frequency_basic() {
    let log = create_perfect_account_log();
    let frequencies = get_activity_frequency(&log);

    // Should have 3 activities: register, examine, decide (each appears 5 times)
    assert_eq!(frequencies.len(), 3);

    // All should appear 5 times total and in 5 distinct traces
    for freq in &frequencies {
        assert_eq!(freq.total_count, 5);
        assert_eq!(freq.distinct_traces, 5);
        assert!((freq.average_per_trace - 1.0).abs() < 1e-6);
    }
}

#[test]
fn test_activity_frequency_ordering() {
    let mut log = EventLog::new();
    let now = Utc::now();

    // Case 1: A -> B -> C
    let mut trace1 = Trace::new("case_1");
    trace1.add_event(Event::new("A", now));
    trace1.add_event(Event::new("B", now + Duration::minutes(10)));
    trace1.add_event(Event::new("C", now + Duration::minutes(20)));
    log.add_trace(trace1);

    // Case 2: A -> B -> A (A appears twice)
    let mut trace2 = Trace::new("case_2");
    trace2.add_event(Event::new("A", now + Duration::hours(1)));
    trace2.add_event(Event::new("B", now + Duration::hours(1) + Duration::minutes(10)));
    trace2.add_event(Event::new("A", now + Duration::hours(1) + Duration::minutes(20)));
    log.add_trace(trace2);

    let frequencies = get_activity_frequency(&log);

    // A: 3 total, 2 distinct traces
    // B: 2 total, 2 distinct traces
    // C: 1 total, 1 distinct trace
    assert_eq!(frequencies.len(), 3);
    assert_eq!(frequencies[0].activity, "A");
    assert_eq!(frequencies[0].total_count, 3);
    assert_eq!(frequencies[0].distinct_traces, 2);
}

#[test]
fn test_activity_frequency_empty() {
    let log = create_empty_log();
    let frequencies = get_activity_frequency(&log);

    assert!(frequencies.is_empty());
}

