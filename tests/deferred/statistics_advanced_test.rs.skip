#[test]
fn test_variant_frequency_basic() {
    let log = create_multi_variant_log();
    let frequencies = get_variant_frequency(&log);

    assert_eq!(frequencies.len(), 2);

    // First variant: 3 out of 5 = 60%
    assert_eq!(frequencies[0].count, 3);
    assert!((frequencies[0].percentage - 60.0).abs() < 1e-6);

    // Second variant: 2 out of 5 = 40%
    assert_eq!(frequencies[1].count, 2);
    assert!((frequencies[1].percentage - 40.0).abs() < 1e-6);
}

#[test]
fn test_variant_frequency_single_variant() {
    let log = create_perfect_account_log();
    let frequencies = get_variant_frequency(&log);

    assert_eq!(frequencies.len(), 1);
    assert_eq!(frequencies[0].count, 5);
    assert!((frequencies[0].percentage - 100.0).abs() < 1e-6);
}

#[test]
fn test_variant_frequency_empty() {
    let log = create_empty_log();
    let frequencies = get_variant_frequency(&log);

    assert!(frequencies.is_empty());
}

// ============================================================================
// Rework Pattern Tests
// ============================================================================

#[test]
fn test_identify_rework_patterns_basic() {
    let log = create_rework_log();
    let rework = identify_rework_patterns(&log);

    assert!(!rework.is_empty());

    // Activity A: appears in cases 1 and 3, with rework
    let a_rework = rework.iter().find(|r| r.activity == "A").unwrap();
    assert_eq!(a_rework.traces_with_rework, 1);  // case_1 has A twice
    assert_eq!(a_rework.total_rework_instances, 1);

    // Activity B: appears in cases 2 and 3 with rework
    let b_rework = rework.iter().find(|r| r.activity == "B").unwrap();
    assert_eq!(b_rework.traces_with_rework, 1);  // case_3 has B three times
    assert_eq!(b_rework.total_rework_instances, 2);  // 3 instances - 1 original = 2 rework
}

#[test]
fn test_rework_count_per_activity() {
    let log = create_rework_log();
    let rework_counts = get_rework_count_per_activity(&log);

    // Activity A: 2 times in case_1
    assert!(rework_counts.contains_key("A"));
    assert_eq!(rework_counts["A"], vec![2]);

    // Activity B: 3 times in case_3
    assert!(rework_counts.contains_key("B"));
    assert_eq!(rework_counts["B"], vec![3]);
}

#[test]
fn test_identify_rework_patterns_no_rework() {
    let log = create_perfect_account_log();
    let rework = identify_rework_patterns(&log);

    assert!(rework.is_empty());
}

#[test]
fn test_identify_rework_patterns_empty() {
    let log = create_empty_log();
    let rework = identify_rework_patterns(&log);

    assert!(rework.is_empty());
}

// ============================================================================
// Resource Allocation Tests
// ============================================================================

#[test]
fn test_resource_metrics_basic() {
    let log = create_resource_log();
    let metrics = get_resource_metrics(&log);

    assert_eq!(metrics.len(), 3);  // clerk, senior, manager

    // All resources appear in all 3 cases = 3 activities each
    let clerk = metrics.iter().find(|m| m.resource == "clerk").unwrap();
    assert_eq!(clerk.total_activities, 3);
    assert_eq!(clerk.unique_activities, 1);  // Only "register"

    let senior = metrics.iter().find(|m| m.resource == "senior").unwrap();
    assert_eq!(senior.total_activities, 3);
    assert_eq!(senior.unique_activities, 1);  // Only "examine"

    let manager = metrics.iter().find(|m| m.resource == "manager").unwrap();
    assert_eq!(manager.total_activities, 3);
    assert_eq!(manager.unique_activities, 1);  // Only "decide"

    // Utilization should be 3/9 = 0.333... for each
    for metric in &metrics {
        assert!((metric.utilization - (3.0/9.0)).abs() < 1e-6);
    }
}

#[test]
fn test_resource_metrics_empty() {
    let log = create_empty_log();
    let metrics = get_resource_metrics(&log);

    assert!(metrics.is_empty());
}

#[test]
fn test_resource_metrics_no_resources() {
    let log = create_perfect_account_log();
    let metrics = get_resource_metrics(&log);

    assert!(metrics.is_empty());  // No resources assigned
}

// ============================================================================
// Activity Throughput Tests
// ============================================================================

#[test]
fn test_activity_throughput_basic() {
    let mut log = EventLog::new();
    let now = Utc::now();

    // Case 1: A (10 sec) -> B (20 sec) -> C
    let mut trace1 = Trace::new("case_1");
    trace1.add_event(Event::new("A", now));
    trace1.add_event(Event::new("B", now + Duration::seconds(10)));
    trace1.add_event(Event::new("C", now + Duration::seconds(30)));
    log.add_trace(trace1);

    // Case 2: A (10 sec) -> B (20 sec) -> C (same timing)
    let mut trace2 = Trace::new("case_2");
    trace2.add_event(Event::new("A", now + Duration::hours(1)));
    trace2.add_event(Event::new("B", now + Duration::hours(1) + Duration::seconds(10)));
    trace2.add_event(Event::new("C", now + Duration::hours(1) + Duration::seconds(30)));
    log.add_trace(trace2);

    let throughput = get_activity_throughput(&log);

    // Should be sorted by duration (descending - bottlenecks first)
    // B has average 20 sec, A has average 10 sec
    assert_eq!(throughput[0].0, "B");
    assert!((throughput[0].1 - 20.0).abs() < 1e-6);

    assert_eq!(throughput[1].0, "A");
    assert!((throughput[1].1 - 10.0).abs() < 1e-6);
}

#[test]
fn test_activity_throughput_empty() {
    let log = create_empty_log();
    let throughput = get_activity_throughput(&log);

    assert!(throughput.is_empty());
}

// ============================================================================
// Case Throughput Tests
// ============================================================================

#[test]
fn test_case_throughput_basic() {
    let mut log = EventLog::new();
    let now = Utc::now();

    // 10 cases spread over 10 days
    for i in 0..10 {
        let mut trace = Trace::new(format!("case_{}", i));
        trace.add_event(Event::new("A", now + Duration::days(i as i64)));
        trace.add_event(Event::new("B", now + Duration::days(i as i64) + Duration::hours(1)));
        log.add_trace(trace);
    }

    let throughput = get_case_throughput(&log);

    // 10 cases / 9 days = 1.111... cases per day
    assert!((throughput - (10.0 / 9.0)).abs() < 1e-6);
}

#[test]
fn test_case_throughput_empty() {
    let log = create_empty_log();
    let throughput = get_case_throughput(&log);

    assert_eq!(throughput, 0.0);
}

#[test]
fn test_case_throughput_single_case() {
    let log = create_single_event_log();
    let throughput = get_case_throughput(&log);

    assert_eq!(throughput, 0.0);  // Need at least 2 cases
}

// ============================================================================
// Bottleneck Activity Tests
// ============================================================================

#[test]
fn test_bottleneck_activities() {
    let mut log = EventLog::new();
    let now = Utc::now();

    // A takes 100 sec, B takes 50 sec, C takes 10 sec
    let mut trace1 = Trace::new("case_1");
    trace1.add_event(Event::new("A", now));
    trace1.add_event(Event::new("B", now + Duration::seconds(100)));
    trace1.add_event(Event::new("C", now + Duration::seconds(150)));
    trace1.add_event(Event::new("D", now + Duration::seconds(160)));
    log.add_trace(trace1);

    let bottlenecks = get_bottleneck_activities(&log, 2);

    assert_eq!(bottlenecks.len(), 2);
    assert_eq!(bottlenecks[0].0, "A");  // 100 sec
    assert_eq!(bottlenecks[1].0, "B");  // 50 sec
}

#[test]
fn test_bottleneck_activities_top_k() {
    let mut log = EventLog::new();
    let now = Utc::now();

    let mut trace = Trace::new("case_1");
    trace.add_event(Event::new("A", now));
    trace.add_event(Event::new("B", now + Duration::seconds(10)));
    trace.add_event(Event::new("C", now + Duration::seconds(15)));
    trace.add_event(Event::new("D", now + Duration::seconds(20)));
    log.add_trace(trace);

    let bottlenecks = get_bottleneck_activities(&log, 1);
    assert_eq!(bottlenecks.len(), 1);
}

// ============================================================================
// Performance Indicators Tests
// ============================================================================

#[test]
fn test_performance_indicators_basic() {
    let mut log = EventLog::new();
    let now = Utc::now();

    // 3 cases over 3 days
    for i in 0..3 {
        let mut trace = Trace::new(format!("case_{}", i));
        trace.add_event(Event::new("A", now + Duration::days(i as i64)));
        trace.add_event(Event::new("B", now + Duration::days(i as i64) + Duration::seconds(100)));
        log.add_trace(trace);
    }

    let indicators = calculate_performance_indicators(&log);

    // Throughput: 3 cases / 2 days = 1.5
    assert!((indicators.case_throughput - 1.5).abs() < 1e-6);

    // Average case duration: 100 seconds
    assert!((indicators.avg_case_duration - 100.0).abs() < 1e-6);

    // Fastest: A (1 second between A and B on average... actually need better test)
    assert!(indicators.fastest_activity.0 != "N/A");
    assert!(indicators.slowest_activity.0 != "N/A");
}

#[test]
fn test_performance_indicators_empty() {
    let log = create_empty_log();
    let indicators = calculate_performance_indicators(&log);

    assert_eq!(indicators.case_throughput, 0.0);
    assert_eq!(indicators.avg_case_duration, 0.0);
    assert_eq!(indicators.fastest_activity.0, "N/A");
    assert_eq!(indicators.slowest_activity.0, "N/A");
}

// ============================================================================
// Edge Cases & Parity Tests
// ============================================================================

#[test]
fn test_median_calculation_even_count() {
    let mut log = EventLog::new();
    let now = Utc::now();

    // Create 2 cases with durations 100 and 200 seconds
    for i in 0..2 {
        let mut trace = Trace::new(format!("case_{}", i));
        trace.add_event(Event::new("A", now + Duration::hours(i as i64)));
        trace.add_event(Event::new("B", now + Duration::hours(i as i64) + Duration::seconds((i + 1) as i64 * 100)));
        log.add_trace(trace);
    }

    let stats = case_duration_distribution(&log);

    // Median of [100, 200] = 150
    assert!((stats.median_duration - 150.0).abs() < 1e-6);
}

#[test]
fn test_median_calculation_odd_count() {
    let mut log = EventLog::new();
    let now = Utc::now();

    // Create 3 cases with durations 100, 200, 300 seconds
    for i in 0..3 {
        let mut trace = Trace::new(format!("case_{}", i));
        trace.add_event(Event::new("A", now + Duration::hours(i as i64)));
        trace.add_event(Event::new("B", now + Duration::hours(i as i64) + Duration::seconds((i + 1) as i64 * 100)));
        log.add_trace(trace);
    }

    let stats = case_duration_distribution(&log);

    // Median of [100, 200, 300] = 200
    assert!((stats.median_duration - 200.0).abs() < 1e-6);
}

#[test]
fn test_parity_with_python_pm4py_standard_log() {
    // This test validates parity with Python pm4py output
    // Input: 10 random invoice cases
    // Expected: statistics match pm4py within 1e-10 relative error

    let mut log = EventLog::new();
    let now = Utc::now();

    for i in 0..10 {
        let mut trace = Trace::new(format!("INV_{:04}", i));

        // Standard process: register -> examine -> decide
        let register_time = now + Duration::hours(i as i64);
        let examine_time = register_time + Duration::minutes(30);
        let decide_time = examine_time + Duration::hours(1);

        trace.add_event(Event::new("register", register_time).with_resource("clerk"));
        trace.add_event(Event::new("examine", examine_time).with_resource("senior"));
        trace.add_event(Event::new("decide", decide_time).with_resource("manager"));

        log.add_trace(trace);
    }

    // Test case duration
    let duration_stats = case_duration_distribution(&log);
    assert_eq!(duration_stats.count, 10);
    // All cases: 30 min + 60 min = 90 min = 5400 seconds
    assert!((duration_stats.mean_duration - 5400.0).abs() < 1e-6);
    assert!(duration_stats.stddev_duration < 1e-6);  // No variance

    // Test activity frequency
    let activity_freqs = get_activity_frequency(&log);
    assert_eq!(activity_freqs.len(), 3);
    for freq in &activity_freqs {
        assert_eq!(freq.total_count, 10);
        assert_eq!(freq.distinct_traces, 10);
    }

    // Test variant frequency
    let variant_freqs = get_variant_frequency(&log);
    assert_eq!(variant_freqs.len(), 1);
    assert_eq!(variant_freqs[0].count, 10);

    // Test resource metrics
    let resource_metrics = get_resource_metrics(&log);
    assert_eq!(resource_metrics.len(), 3);
}

#[test]
fn test_parity_numeric_precision() {
    // Test numeric precision for edge cases
    let mut log = EventLog::new();
    let base = Utc::now();

    // Create cases with very small time differences (nanosecond precision)
    for i in 0..5 {
        let mut trace = Trace::new(format!("case_{}", i));
        trace.add_event(Event::new("A", base + Duration::milliseconds(i as i64 * 1000)));
        trace.add_event(Event::new("B", base + Duration::milliseconds(i as i64 * 1000 + 500)));
        log.add_trace(trace);
    }

    let stats = case_duration_distribution(&log);

    // All durations should be exactly 500 ms = 0.5 seconds
    assert!((stats.min_duration - 0.5).abs() < 1e-9);
    assert!((stats.max_duration - 0.5).abs() < 1e-9);
    assert!((stats.mean_duration - 0.5).abs() < 1e-9);
    assert!(stats.stddev_duration < 1e-9);
}

#[test]
fn test_handle_ties_in_activity_frequency() {
    let mut log = EventLog::new();
    let now = Utc::now();

    // Two activities with same count
    let mut trace1 = Trace::new("case_1");
    trace1.add_event(Event::new("A", now));
    trace1.add_event(Event::new("B", now + Duration::minutes(10)));
    log.add_trace(trace1);

    let mut trace2 = Trace::new("case_2");
    trace2.add_event(Event::new("C", now + Duration::hours(1)));
    trace2.add_event(Event::new("D", now + Duration::hours(1) + Duration::minutes(10)));
    log.add_trace(trace2);

    let frequencies = get_activity_frequency(&log);

    // Should have 4 activities, all with count=1
    assert_eq!(frequencies.len(), 4);
    for freq in &frequencies {
        assert_eq!(freq.total_count, 1);
    }
}
