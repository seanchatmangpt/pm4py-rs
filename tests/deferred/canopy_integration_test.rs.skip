// ============================================================================
// INNOVATION 18: Alpha vs Inductive vs Heuristic Comparison
// ============================================================================

#[test]
fn test_canopy_miner_comparison() {
    let log = load_compliance();

    let alpha_net = AlphaMiner::new().discover(&log);
    let inductive_net = InductiveMiner::new().discover(&log);
    let heuristic_net = HeuristicMiner::new().discover(&log);

    println!("Miner Comparison on Compliance:");
    println!(
        "   Alpha: {} places, {} transitions, {} arcs",
        alpha_net.places.len(),
        alpha_net.transitions.len(),
        alpha_net.arcs.len()
    );
    println!(
        "   Inductive: {} places, {} transitions, {} arcs",
        inductive_net.places.len(),
        inductive_net.transitions.len(),
        inductive_net.arcs.len()
    );
    println!(
        "   Heuristic: {} places, {} transitions, {} arcs",
        heuristic_net.places.len(),
        heuristic_net.transitions.len(),
        heuristic_net.arcs.len()
    );

    assert!(!alpha_net.transitions.is_empty());
    assert!(!inductive_net.transitions.is_empty());
    assert!(!heuristic_net.transitions.is_empty());
}

// ============================================================================
// INNOVATION 19: Conformance Comparison Across Miners
// ============================================================================

#[test]
fn test_canopy_conformance_comparison() {
    let log = load_invoice();

    let inductive_net = InductiveMiner::new().discover(&log);
    let heuristic_net = HeuristicMiner::new().discover(&log);

    let ind_result = AlignmentChecker::new().check(&log, &inductive_net);
    let heur_result = AlignmentChecker::new().check(&log, &heuristic_net);

    println!("Conformance Comparison:");
    println!(
        "   Inductive: fitness={:.4}, precision={:.4}",
        ind_result.fitness, ind_result.precision
    );
    println!(
        "   Heuristic: fitness={:.4}, precision={:.4}",
        heur_result.fitness, heur_result.precision
    );

    assert!(ind_result.fitness >= 0.0);
    assert!(heur_result.fitness >= 0.0);
}

// ============================================================================
// INNOVATION 20: Synthetic Agent Lifecycle (Chicago TDD with programmatic log)
// ============================================================================

#[test]
fn test_synthetic_agent_lifecycle_discovery() {
    let mut log = EventLog::new();

    // Simulate 10 agent lifecycles
    for i in 0..10 {
        let mut trace = Trace::new(format!("agent_{}", i));

        trace.add_event(
            Event::new("agent_spawn", Utc::now() - Duration::hours(1))
                .with_attribute("agent_id", format!("agent_{}", i))
                .with_attribute("spawn_type", "goal_dispatch"),
        );

        trace.add_event(
            Event::new("initialize_memory", Utc::now() - Duration::minutes(55))
                .with_attribute("agent_id", format!("agent_{}", i)),
        );

        trace.add_event(
            Event::new("tool_execute", Utc::now() - Duration::minutes(50))
                .with_attribute("agent_id", format!("agent_{}", i))
                .with_attribute("tool_name", "file_read"),
        );

        trace.add_event(
            Event::new("tool_execute", Utc::now() - Duration::minutes(45))
                .with_attribute("agent_id", format!("agent_{}", i))
                .with_attribute("tool_name", "brainstorm"),
        );

        trace.add_event(
            Event::new("llm_request", Utc::now() - Duration::minutes(40))
                .with_attribute("agent_id", format!("agent_{}", i))
                .with_attribute("provider", "anthropic"),
        );

        trace.add_event(
            Event::new("llm_response", Utc::now() - Duration::minutes(39))
                .with_attribute("agent_id", format!("agent_{}", i))
                .with_attribute("tokens_used", "1234"),
        );

        trace.add_event(
            Event::new("goal_achieved", Utc::now() - Duration::minutes(5))
                .with_attribute("agent_id", format!("agent_{}", i)),
        );

        trace.add_event(
            Event::new("agent_terminate", Utc::now())
                .with_attribute("agent_id", format!("agent_{}", i))
                .with_attribute("termination_reason", "success"),
        );

        log.add_trace(trace);
    }

    let dfg = DFGMiner::new().discover(&log);
    let net = InductiveMiner::new().discover(&log);
    let result = TokenReplay::new().check(&log, &net);

    println!("Agent Lifecycle Discovery:");
    println!("   Traces: {}", log.traces.len());
    println!("   DFG activities: {}", dfg.nodes.len());
    println!("   DFG edges: {}", dfg.edges.len());
    println!("   Petri net places: {}", net.places.len());
    println!("   Fitness: {:.4}", result.fitness);

    assert_eq!(log.traces.len(), 10, "Should have 10 agent traces");
    assert!(!dfg.nodes.is_empty(), "Should discover DFG");
}
