#[test]
fn test_canopy_paths_performance_filter() {
    let log = load_invoice();
    let activities: Vec<String> = activity_frequency(&log).keys().cloned().collect();

    if activities.len() >= 2 {
        // Filter for paths taking less than 7 days (604800 seconds)
        let filtered = filter_paths_performance(&log, &activities[0], &activities[1], 0.0, 604800.0);
