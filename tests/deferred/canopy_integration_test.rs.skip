#[test]
fn test_canopy_performance_dfg_with_metrics() {
    let log = load_invoice();
    let perf_dfg = discover_performance_dfg(&log);

    println!("Performance DFG:");
    println!("   Activities: {}", perf_dfg.activities.len());
    println!("   Frequency edges: {}", perf_dfg.frequency.len());
    println!("   Performance edges: {}", perf_dfg.performance.len());

    for ((from, to), perf) in perf_dfg.performance.iter().take(5) {
