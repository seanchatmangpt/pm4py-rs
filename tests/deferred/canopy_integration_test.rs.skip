// ============================================================================
// INNOVATION 13: Four-Eyes Principle in Invoice Approval
// ============================================================================

#[test]
fn test_canopy_four_eyes_principle() {
    let log = load_invoice();

    // Find activities that look like submit/approve
    let activities: Vec<String> = activity_frequency(&log).keys().cloned().collect();
    let submit_like = activities
        .iter()
        .find(|a| a.to_lowercase().contains("submit"))
        .map(|s| s.as_str())
        .unwrap_or("");
    let approve_like = activities
        .iter()
        .find(|a| a.to_lowercase().contains("approve"))
        .map(|s| s.as_str())
        .unwrap_or("");

    if !submit_like.is_empty() && !approve_like.is_empty() {
        let filtered = filter_four_eyes_principle(&log, submit_like, approve_like);
        println!(
            "Four-eyes ({} vs {}): {} of {} traces pass",
            submit_like,
            approve_like,
            filtered.traces.len(),
            log.traces.len()
        );
    }
}

// ============================================================================
// INNOVATION 14: Directly-Follows Filter
// ============================================================================

#[test]
fn test_canopy_directly_follows_filter() {
    let log = load_invoice();
    let activities: Vec<String> = activity_frequency(&log).keys().cloned().collect();

    if activities.len() >= 2 {
        let filtered =
            filter_directly_follows_relation(&log, &activities[0], &activities[1]);
        println!(
            "DF filter ({} -> {}): {} of {} traces",
            activities[0],
            activities[1],
            filtered.traces.len(),
            log.traces.len()
        );
    }
}

// ============================================================================
// INNOVATION 15: Rework Detection in Business Processes
// ============================================================================

#[test]
fn test_canopy_rework_detection() {
    let log = load_onboarding();
    let activities: Vec<String> = activity_frequency(&log).keys().cloned().collect();

    // Try to find rework for each activity
    for activity in &activities {
        let rework_traces = filter_activities_rework(&log, activity);
        if rework_traces.traces.len() > 0 {
            println!(
                "Rework on '{}': {} of {} traces",
                activity,
                rework_traces.traces.len(),
                log.traces.len()
            );
        }
    }
}

