#[test]
fn test_canopy_bottleneck_detection() {
    let log = load_onboarding();
    let freq = activity_frequency(&log);

    println!("Bottleneck Detection:");
    println!("   Activities found: {}", freq.len());

    let mut sorted_freq: Vec<_> = freq.iter().collect();
    sorted_freq.sort_by(|a, b| b.1.cmp(a.1));

    println!("   Top 5 activities by frequency:");
    for (i, (activity, count)) in sorted_freq.iter().take(5).enumerate() {
        println!("     {}. {}: {} occurrences", i + 1, activity, count);
    }

    assert!(!freq.is_empty(), "Should have activity frequencies");
}

// ============================================================================
// INNOVATION 8: Temporal Pattern Analysis
// ============================================================================

#[test]
fn test_canopy_temporal_patterns() {
    let log = load_compliance();
    let starts = start_activities(&log);
    let ends = end_activities(&log);

    println!("Temporal Pattern Analysis:");
    println!("   Start activities: {:?}", starts);
    println!("   End activities: {:?}", ends);

    let timestamps: Vec<_> = log
        .traces
        .iter()
        .flat_map(|t| t.events.iter().map(|e| e.timestamp))
        .collect();

    if let (Some(min_ts), Some(max_ts)) = (timestamps.iter().min(), timestamps.iter().max()) {
        println!(
            "   Earliest event: {}",
            min_ts.format("%Y-%m-%d %H:%M")
        );
        println!(
            "   Latest event: {}",
            max_ts.format("%Y-%m-%d %H:%M")
        );
    }

    assert!(!starts.is_empty(), "Should have start activities");
    assert!(!ends.is_empty(), "Should have end activities");
}

// ============================================================================
// INNOVATION 9: DFG Visualization Generation
// ============================================================================

#[test]
fn test_canopy_dfg_visualization() {
    let log = load_invoice();
    let dfg = DFGMiner::new().discover(&log);
    let svg = svg_renderer::render_dfg_svg(&dfg, &svg_renderer::SvgRenderOptions::default());

    println!("DFG Visualization:");
    println!("   SVG generated: {} bytes", svg.len());
    println!("   Contains <svg>: {}", svg.contains("<svg"));
    println!("   DFG nodes: {}", dfg.nodes.len());

    assert!(svg.contains("<svg"), "Should generate valid SVG");
    assert!(svg.len() > 100, "SVG should have content");
}

// ============================================================================
// INNOVATION 10: Filter and Sub-log Analysis
// ============================================================================

#[test]
fn test_canopy_advanced_filtering() {
    let log = load_onboarding();
    let original_size = log.traces.len();

    // Get first activity name to use for prefix filter
    let first_activity = log
        .traces
        .first()
        .and_then(|t| t.events.first())
        .map(|e| e.activity.clone())
        .unwrap_or_default();

    let filtered = filter_trace_prefix(&log, &[first_activity.clone()]);
    println!("Advanced Filtering:");
    println!("   Original traces: {}", original_size);
    println!(
        "   After prefix filter ('{}'): {}",
        first_activity,
        filtered.traces.len()
    );

    let size_filtered = filter_case_size(&log, 2, 100);
    println!("   After size filter (2-100): {}", size_filtered.traces.len());

    // Filter traces containing any activity with "approve" in the name
    let activities: Vec<String> = activity_frequency(&log)
        .keys()
        .filter(|a| a.to_lowercase().contains("approve"))
        .cloned()
        .collect();

    if let Some(approve_act) = activities.first() {
        let activity_filtered = filter_traces_containing_activity(&log, approve_act);
        println!(
            "   Traces with '{}': {}",
            approve_act,
            activity_filtered.traces.len()
        );
    }

    assert!(filtered.traces.len() > 0 || original_size == 0, "Filter should work");
}

// ============================================================================
// INNOVATION 11: End-to-End Pipeline Test
// ============================================================================

#[test]
fn test_canopy_end_to_end_pipeline() {
    let log = load_compliance();

    // Step 1: Load (already done)
    println!("Step 1: Loaded {} traces", log.traces.len());

    // Step 2: Statistics
    let stats = log_statistics(&log);
    println!(
        "Step 2: Stats - {} events, {:.1} avg length",
        stats.num_events, stats.avg_trace_length
    );

    // Step 3: Discovery
    let dfg = DFGMiner::new().discover(&log);
    let net = InductiveMiner::new().discover(&log);
    println!(
        "Step 3: Discovered DFG ({} nodes) and Petri net ({} places)",
        dfg.nodes.len(),
        net.places.len()
    );

    // Step 4: Conformance
    let result = TokenReplay::new().check(&log, &net);
    println!(
        "Step 4: Conformance - fitness={:.4}, precision={:.4}",
        result.fitness, result.precision
    );

    // Step 5: Visualization
    let svg = svg_renderer::render_dfg_svg(&dfg, &svg_renderer::SvgRenderOptions::default());
    println!("Step 5: Generated {} bytes of SVG", svg.len());

    assert!(!log.traces.is_empty(), "Pipeline: should load data");
    assert!(stats.num_events > 0, "Pipeline: should compute stats");
    assert!(!dfg.nodes.is_empty(), "Pipeline: should discover DFG");
    assert!(svg.contains("<svg"), "Pipeline: should generate visualization");
}

