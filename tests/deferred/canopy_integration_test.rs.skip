//! INTEGRATION TESTS: pm4py-rust with Canopy demo data
//!
//! Chicago TDD: NO MOCKS. All tests use REAL data from Canopy's workspace protocol.
//!
//! Data sources (real CSVs at canopy/priv/demo_data/):
//! - invoice_processing_events.csv: Invoice approval workflow (425KB)
//! - customer_onboarding_events.csv: Customer onboarding process (385KB)
//! - compliance_reporting_events.csv: SOC2 compliance reporting (294KB)

use chrono::{Duration, Utc};
use pm4py::conformance::{AlignmentChecker, TokenReplay};
use pm4py::discovery::{
    AlphaMiner, DFGMiner, HeuristicMiner, InductiveMiner, discover_performance_dfg,
    discover_prefix_tree,
};
use pm4py::io::CSVReader;
use pm4py::log::{
    Event, EventLog, Trace, activity_frequency, directly_follows, end_activities,
    filter_activities_rework, filter_case_size, filter_directly_follows_relation,
    filter_four_eyes_principle, filter_paths_performance, filter_trace_prefix,
    filter_traces_containing_activity, start_activities, variants,
};
use pm4py::statistics::log_statistics;
use pm4py::visualization::svg_renderer;
use std::collections::HashMap;
use std::path::Path;

const CANOPY_DATA_DIR: &str = "/Users/sac/chatmangpt/canopy/priv/demo_data";

fn canopy_csv() -> CSVReader {
    CSVReader::new()
        .with_case_column("case_id")
        .with_activity_column("activity")
        .with_timestamp_column("timestamp")
        .with_resource_column(Some("resource"))
}

fn load_invoice() -> EventLog {
    canopy_csv()
        .read(Path::new(&format!("{}/invoice_processing_events.csv", CANOPY_DATA_DIR)))
        .expect("Failed to load invoice CSV")
}

fn load_onboarding() -> EventLog {
    canopy_csv()
        .read(Path::new(&format!(
            "{}/customer_onboarding_events.csv",
            CANOPY_DATA_DIR
        )))
        .expect("Failed to load onboarding CSV")
}

fn load_compliance() -> EventLog {
    canopy_csv()
        .read(Path::new(&format!(
            "{}/compliance_reporting_events.csv",
            CANOPY_DATA_DIR
        )))
        .expect("Failed to load compliance CSV")
}

// ============================================================================
// INNOVATION 1: Cross-Project Process Discovery
// ============================================================================

#[test]
fn test_canopy_invoice_process_discovery() {
    let log = load_invoice();
    println!(
        "Invoice Processing Log: {} traces",
        log.traces.len()
    );
    println!(
        "   Total events: {}",
        log.traces.iter().map(|t| t.events.len()).sum::<usize>()
    );

    let dfg = DFGMiner::new().discover(&log);
    let net = AlphaMiner::new().discover(&log);
    let inductive_net = InductiveMiner::new().discover(&log);
    let heuristic_net = HeuristicMiner::new().discover(&log);

    println!("   DFG nodes: {}", dfg.nodes.len());
    println!("   Alpha Miner places: {}", net.places.len());
    println!("   Inductive places: {}", inductive_net.places.len());
    println!("   Heuristic places: {}", heuristic_net.places.len());

    assert!(!dfg.nodes.is_empty(), "DFG should have activities");
    assert!(!net.places.is_empty(), "Petri net should have places");
    assert!(!net.transitions.is_empty(), "Petri net should have transitions");
}

// ============================================================================
// INNOVATION 2: Real-World Performance Analytics
// ============================================================================

#[test]
fn test_canopy_onboarding_performance_analytics() {
    let log = load_onboarding();

    let stats = log_statistics(&log);
    let perf_dfg = discover_performance_dfg(&log);

    println!("Onboarding Performance:");
    println!("   Total cases: {}", log.traces.len());
    println!("   Avg trace length: {:.1}", stats.avg_trace_length);
    println!("   Performance DFG edges: {}", perf_dfg.frequency.len());

    assert!(!log.traces.is_empty(), "Should have onboarding cases");
    assert!(stats.num_events > 0, "Should have events");
}

// ============================================================================
// INNOVATION 3: Compliance Process Conformance
// ============================================================================

#[test]
fn test_canopy_compliance_conformance_checking() {
    let log = load_compliance();
    let net = InductiveMiner::new().discover(&log);
    let result = TokenReplay::new().check(&log, &net);

    println!("Compliance Conformance:");
    println!("   Traces checked: {}", log.traces.len());
    println!("   Fitness: {:.4}", result.fitness);
    println!("   Precision: {:.4}", result.precision);
    println!("   Conformant: {}", result.is_conformant);

    assert!(result.fitness >= 0.0 && result.fitness <= 1.0, "Fitness should be 0-1");
}

// ============================================================================
// INNOVATION 4: Multi-Process Comparison
// ============================================================================

#[test]
fn test_canopy_multi_process_comparison() {
    let invoice_log = load_invoice();
    let onboarding_log = load_onboarding();
    let compliance_log = load_compliance();

    let invoice_stats = log_statistics(&invoice_log);
    let onboarding_stats = log_statistics(&onboarding_log);
    let compliance_stats = log_statistics(&compliance_log);

    println!("Multi-Process Comparison:");
    println!(
        "   Invoice: {} traces, {} events",
        invoice_log.traces.len(),
        invoice_stats.num_events
    );
    println!(
        "   Onboarding: {} traces, {} events",
        onboarding_log.traces.len(),
        onboarding_stats.num_events
    );
    println!(
        "   Compliance: {} traces, {} events",
        compliance_log.traces.len(),
        compliance_stats.num_events
    );

    let invoice_activities = activity_frequency(&invoice_log).len();
    let onboarding_activities = activity_frequency(&onboarding_log).len();
    let compliance_activities = activity_frequency(&compliance_log).len();

    println!(
        "   Activity variety: Invoice={}, Onboarding={}, Compliance={}",
        invoice_activities, onboarding_activities, compliance_activities
    );

    assert!(!invoice_log.traces.is_empty());
    assert!(!onboarding_log.traces.is_empty());
    assert!(!compliance_log.traces.is_empty());
}

// ============================================================================
// INNOVATION 5: Resource Social Network Analysis
// ============================================================================

#[test]
fn test_canopy_resource_social_network() {
    let log = load_invoice();
    let resource_activity = pm4py::discovery::discover_activity_based_resource_similarity(&log);
    let df = directly_follows(&log);

    println!("Resource Social Network:");
    println!("   Resource-activity pairs: {}", resource_activity.len());
    println!("   Directly-follows relations: {}", df.len());

    // Count resource occurrences from events
    let mut resource_counts: HashMap<String, usize> = HashMap::new();
    for trace in &log.traces {
        for event in &trace.events {
            if let Some(ref resource) = event.resource {
                *resource_counts.entry(resource.clone()).or_insert(0) += 1;
            }
        }
    }

    let mut sorted_resources: Vec<_> = resource_counts.iter().collect();
    sorted_resources.sort_by(|a, b| b.1.cmp(a.1));

    println!("   Top 5 resources:");
    for (i, (resource, count)) in sorted_resources.iter().take(5).enumerate() {
        println!("     {}. {}: {} events", i + 1, resource, count);
    }

    assert!(!resource_activity.is_empty(), "Should have resource data");
}

// ============================================================================
// INNOVATION 6: Variant Analysis
// ============================================================================

#[test]
fn test_canopy_variant_analysis() {
    let log = load_invoice();
    let vars = variants(&log);

    println!("Variant Analysis:");
    println!("   Total variants: {}", vars.len());

    let mut sorted_vars: Vec<_> = vars.iter().collect();
    sorted_vars.sort_by(|a, b| b.1.cmp(a.1));

    println!("   Top 5 variants:");
    for (i, (variant_str, count)) in sorted_vars.iter().take(5).enumerate() {
        let percentage = (**count as f64 / log.traces.len() as f64) * 100.0;
        println!(
            "     {}. {} cases ({:.1}%) - {}",
            i + 1,
            count,
            percentage,
            variant_str
        );
    }

    assert!(!vars.is_empty(), "Should have process variants");
}

