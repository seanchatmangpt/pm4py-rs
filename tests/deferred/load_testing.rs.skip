/// Load Testing Suite for pm4py-rust
///
/// Validates system behavior under extreme concurrent load conditions:
/// - Concurrent discovery requests (10, 50, 100 simultaneous)
/// - Concurrent conformance checks (10, 50, 100 simultaneous)
/// - Concurrent statistics calculations
/// - Ensures no deadlocks, data corruption, or memory leaks
///
/// Test Categories:
/// 1. Discovery Concurrency: Parallel Alpha Miner with large event logs
/// 2. Conformance Concurrency: Parallel Token Replay conformance checks
/// 3. Statistics Concurrency: Parallel statistical analysis
/// 4. Mixed Operations: Concurrent discovery + conformance + statistics
/// 5. Resource Exhaustion: Sustaining operations near heap limits
/// 6. Cancellation & Recovery: Graceful degradation under overload

use pm4py::log::{Event, EventLog, Trace};
use pm4py::discovery::AlphaMiner;
use pm4py::conformance::TokenReplay;
use pm4py::statistics::log_stats;
use chrono::{Duration, Utc};
use std::sync::{Arc, atomic::{AtomicUsize, Ordering}};
use std::thread;
use std::time::Instant;

// ============================================================================
// HELPER: Log Generation
// ============================================================================

/// Generate a realistic event log with N traces
fn generate_test_log(num_traces: usize, events_per_trace: usize) -> EventLog {
    let mut log = EventLog::new();
    let base_time = Utc::now();

    for trace_id in 0..num_traces {
        let mut trace = Trace::new(format!("TRACE_{}", trace_id));
        let mut event_time = base_time + Duration::hours(trace_id as i64);

        for event_seq in 0..events_per_trace {
            let activity = match event_seq % 7 {
                0 => "start",
                1 => "verify",
                2 => "process",
                3 => "check",
                4 => "approve",
                5 => "execute",
                _ => "complete",
            };

            trace.add_event(Event::new(activity, event_time));
            event_time += Duration::minutes(5);

            // Add optional rework loop (20% of cases)
            if event_seq == 3 && trace_id % 5 == 0 {
                trace.add_event(Event::new("rework", event_time));
                event_time += Duration::minutes(10);
                trace.add_event(Event::new("verify", event_time));
                event_time += Duration::minutes(5);
            }
        }

        log.add_trace(trace);
    }

    log
}

/// Generate a large log for stress testing
fn generate_large_log(total_events: usize) -> EventLog {
    let mut log = EventLog::new();
    let base_time = Utc::now();
    let mut event_count = 0;
    let mut trace_id = 0;

    while event_count < total_events {
        let mut trace = Trace::new(format!("TRACE_{}", trace_id));
        let mut event_time = base_time + Duration::hours(trace_id as i64);

        let events_in_this_trace = std::cmp::min(50, total_events - event_count);

        for event_seq in 0..events_in_this_trace {
            let activity = match event_seq % 7 {
                0 => "start",
                1 => "verify",
                2 => "process",
                3 => "check",
                4 => "approve",
                5 => "execute",
                _ => "complete",
            };

            trace.add_event(Event::new(activity, event_time));
            event_time += Duration::minutes(5);
            event_count += 1;
        }

        log.add_trace(trace);
        trace_id += 1;
    }

    log
}

// ============================================================================
// TEST 1: CONCURRENT DISCOVERY (10 simultaneous)
// ============================================================================

#[test]
fn test_concurrent_discovery_10_simultaneous() {
    println!("\n=== CONCURRENT DISCOVERY: 10 Simultaneous ===");

    let log = Arc::new(generate_test_log(100, 10));
    let success_count = Arc::new(AtomicUsize::new(0));
    let error_count = Arc::new(AtomicUsize::new(0));
    let mut handles = vec![];

    let start = Instant::now();

    for i in 0..10 {
        let log_clone = Arc::clone(&log);
        let success_clone = Arc::clone(&success_count);
        let error_clone = Arc::clone(&error_count);

        let handle = thread::spawn(move || {
            let miner = AlphaMiner::new();
            let model = miner.discover(log_clone.as_ref());

            // Verify model validity
            if !model.places().is_empty() && !model.transitions().is_empty() {
                success_clone.fetch_add(1, Ordering::SeqCst);
                println!("  Thread {} completed successfully", i);
            } else {
                error_clone.fetch_add(1, Ordering::SeqCst);
            }
        });

        handles.push(handle);
    }

    for handle in handles {
        let _ = handle.join();
    }

    let elapsed = start.elapsed();
    let successes = success_count.load(Ordering::SeqCst);
    let errors = error_count.load(Ordering::SeqCst);

    println!("  Completed in: {:?}", elapsed);
    println!("  Successes: {}, Errors: {}", successes, errors);

    assert_eq!(successes, 10, "Not all discoveries completed successfully");
    assert_eq!(errors, 0, "Unexpected errors during concurrent discovery");
    assert!(elapsed.as_secs() < 30, "Discovery took too long");
}

