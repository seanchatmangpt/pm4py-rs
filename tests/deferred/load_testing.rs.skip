// ============================================================================
// TEST 4: CONCURRENT CONFORMANCE (10 simultaneous)
// ============================================================================

#[test]
fn test_concurrent_conformance_10_simultaneous() {
    println!("\n=== CONCURRENT CONFORMANCE: 10 Simultaneous ===");

    let log = Arc::new(generate_test_log(100, 10));
    let miner = AlphaMiner::new();
    let model = Arc::new(miner.discover(log.as_ref()));
    let success_count = Arc::new(AtomicUsize::new(0));
    let mut handles = vec![];

    let start = Instant::now();

    for i in 0..10 {
        let log_clone = Arc::clone(&log);
        let model_clone = Arc::clone(&model);
        let success_clone = Arc::clone(&success_count);

        let handle = thread::spawn(move || {
            let checker = TokenReplay::new();
            match checker.replay(log_clone.as_ref(), &model_clone) {
                Ok(result) => {
                    let fitness = result.fitness();
                    if fitness >= 0.0 && fitness <= 1.0 {
                        success_clone.fetch_add(1, Ordering::SeqCst);
                        println!("  Thread {}: Fitness {}", i, fitness);
                    }
                }
                Err(_e) => {
                    // Failed gracefully
                }
            }
        });

        handles.push(handle);
    }

    for handle in handles {
        let _ = handle.join();
    }

    let elapsed = start.elapsed();
    let successes = success_count.load(Ordering::SeqCst);

    println!("  Completed in: {:?}", elapsed);
    println!("  Successes: {}", successes);

    assert!(successes >= 5, "Not enough conformance checks completed");
    assert!(elapsed.as_secs() < 30, "Conformance check timeout");
}

