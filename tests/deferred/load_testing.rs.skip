// ============================================================================
// TEST 7: CONCURRENT STATISTICS (50 simultaneous)
// ============================================================================

#[test]
fn test_concurrent_statistics_50_simultaneous() {
    println!("\n=== CONCURRENT STATISTICS: 50 Simultaneous ===");

    let log = Arc::new(generate_test_log(100, 10));
    let success_count = Arc::new(AtomicUsize::new(0));
    let mut handles = vec![];

    let start = Instant::now();

    for _i in 0..50 {
        let log_clone = Arc::clone(&log);
        let success_clone = Arc::clone(&success_count);

        let handle = thread::spawn(move || {
            let num_traces = log_clone.traces().len();
            let num_events: usize = log_clone.traces().iter()
                .map(|t| t.events().len())
                .sum();

            if num_events > 0 && num_traces > 0 {
                success_clone.fetch_add(1, Ordering::SeqCst);
            }
        });

        handles.push(handle);
    }

    for handle in handles {
        let _ = handle.join();
    }

    let elapsed = start.elapsed();
    let successes = success_count.load(Ordering::SeqCst);

    println!("  Completed in: {:?}", elapsed);
    println!("  Successes: {}", successes);

    assert_eq!(successes, 50, "Not all statistics calculations completed");
    assert!(elapsed.as_secs() < 30, "Statistics timeout");
}

// ============================================================================
// TEST 8: MIXED CONCURRENT OPERATIONS (10 each)
// ============================================================================

#[test]
fn test_mixed_concurrent_operations() {
    println!("\n=== MIXED CONCURRENT OPERATIONS (10 discovery, 10 conformance, 10 statistics) ===");

    let log = Arc::new(generate_test_log(100, 10));
    let miner = AlphaMiner::new();
    let model = Arc::new(miner.discover(log.as_ref()));

    let discovery_count = Arc::new(AtomicUsize::new(0));
    let conformance_count = Arc::new(AtomicUsize::new(0));
    let stats_count = Arc::new(AtomicUsize::new(0));

    let mut handles = vec![];

    let start = Instant::now();

    // Spawn 10 discovery threads
    for _i in 0..10 {
        let log_clone = Arc::clone(&log);
        let count_clone = Arc::clone(&discovery_count);

        let handle = thread::spawn(move || {
            let miner = AlphaMiner::new();
            let m = miner.discover(log_clone.as_ref());

            if !m.places().is_empty() {
                count_clone.fetch_add(1, Ordering::SeqCst);
            }
        });

        handles.push(handle);
    }

    // Spawn 10 conformance threads
    for _i in 0..10 {
        let log_clone = Arc::clone(&log);
        let model_clone = Arc::clone(&model);
        let count_clone = Arc::clone(&conformance_count);

        let handle = thread::spawn(move || {
            let checker = TokenReplay::new();
            if let Ok(r) = checker.replay(log_clone.as_ref(), &model_clone) {
                let fitness = r.fitness();
                if fitness >= 0.0 {
                    count_clone.fetch_add(1, Ordering::SeqCst);
                }
            }
        });

        handles.push(handle);
    }

    // Spawn 10 statistics threads
    for _i in 0..10 {
        let log_clone = Arc::clone(&log);
        let count_clone = Arc::clone(&stats_count);

        let handle = thread::spawn(move || {
            let num_events: usize = log_clone.traces().iter()
                .map(|t| t.events().len())
                .sum();

            if num_events > 0 {
                count_clone.fetch_add(1, Ordering::SeqCst);
            }
        });

        handles.push(handle);
    }

    for handle in handles {
        let _ = handle.join();
    }

    let elapsed = start.elapsed();

    println!("  Completed in: {:?}", elapsed);
    println!("  Discoveries: {}, Conformance: {}, Statistics: {}",
        discovery_count.load(Ordering::SeqCst),
        conformance_count.load(Ordering::SeqCst),
        stats_count.load(Ordering::SeqCst)
    );

    assert!(discovery_count.load(Ordering::SeqCst) >= 8);
    assert!(conformance_count.load(Ordering::SeqCst) >= 5);
    assert_eq!(stats_count.load(Ordering::SeqCst), 10);
    assert!(elapsed.as_secs() < 60, "Mixed operations timeout");
}

// ============================================================================
// TEST 9: LARGE LOG PROCESSING (1M events)
// ============================================================================

#[test]
fn test_large_log_single_thread() {
    println!("\n=== LARGE LOG PROCESSING (100k events, single thread) ===");

    let log = generate_large_log(100_000);
    let total_events: usize = log.traces().iter()
        .map(|t| t.events().len())
        .sum();

    println!("  Generated log with {} events", total_events);

    let start = Instant::now();

    let miner = AlphaMiner::new();
    let model = miner.discover(&log);
    let discovery_time = start.elapsed();

    println!("  Discovery completed in: {:?}", discovery_time);
    println!("  Places: {}, Transitions: {}",
        model.places().len(),
        model.transitions().len()
    );

    assert!(!model.places().is_empty());
    assert!(!model.transitions().is_empty());
    assert!(discovery_time.as_secs() < 60, "Large log processing timeout");
}

// ============================================================================
// TEST 10: RESOURCE CONTENTION (All operations simultaneously)
// ============================================================================

#[test]
fn test_resource_contention_all_concurrent() {
    println!("\n=== RESOURCE CONTENTION (All operations simultaneously) ===");

    let log = Arc::new(generate_test_log(100, 10));
    let miner = AlphaMiner::new();
    let model = Arc::new(miner.discover(log.as_ref()));

    let total_completed = Arc::new(AtomicUsize::new(0));
    let mut handles = vec![];

    let start = Instant::now();

    // Spawn 30 threads of each operation type
    for _i in 0..30 {
        // Discovery threads
        {
            let log_clone = Arc::clone(&log);
            let total_clone = Arc::clone(&total_completed);

            let handle = thread::spawn(move || {
                let miner = AlphaMiner::new();
                let _m = miner.discover(log_clone.as_ref());
                total_clone.fetch_add(1, Ordering::SeqCst);
            });
            handles.push(handle);
        }

        // Conformance threads
        {
            let log_clone = Arc::clone(&log);
            let model_clone = Arc::clone(&model);
            let total_clone = Arc::clone(&total_completed);

            let handle = thread::spawn(move || {
                let checker = TokenReplay::new();
                let _r = checker.replay(log_clone.as_ref(), &model_clone);
                total_clone.fetch_add(1, Ordering::SeqCst);
            });
            handles.push(handle);
        }

        // Statistics threads
        {
            let log_clone = Arc::clone(&log);
            let total_clone = Arc::clone(&total_completed);

            let handle = thread::spawn(move || {
                let _num_events: usize = log_clone.traces().iter()
                    .map(|t| t.events().len())
                    .sum();
                total_clone.fetch_add(1, Ordering::SeqCst);
            });
            handles.push(handle);
        }
    }

    for handle in handles {
        let _ = handle.join();
    }

    let elapsed = start.elapsed();
    let completed = total_completed.load(Ordering::SeqCst);

    println!("  Total time: {:?}", elapsed);
    println!("  Total operations completed: {}", completed);

    assert_eq!(completed, 90, "Not all operations completed");
    assert!(elapsed.as_secs() < 180, "Resource contention test timeout");
}

// ============================================================================
// TEST 11: BATCH OPERATIONS (Sequential load)
// ============================================================================

#[test]
fn test_batch_discovery_sequential() {
    println!("\n=== BATCH DISCOVERY (100 sequential operations) ===");

    let mut success_count = 0;
    let start = Instant::now();

    for i in 0..100 {
        let log = generate_test_log(50, 7);
        let miner = AlphaMiner::new();
        let model = miner.discover(&log);

        if !model.places().is_empty() {
            success_count += 1;
        }

        if (i + 1) % 20 == 0 {
            println!("  Completed {} batch operations", i + 1);
        }
    }

    let elapsed = start.elapsed();

    println!("  Completed {} operations in: {:?}", success_count, elapsed);
    assert_eq!(success_count, 100, "Not all batch discoveries completed");
}

// ============================================================================
// TEST 12: MEMORY STABILITY (Long-running operations)
// ============================================================================

#[test]
fn test_memory_stability_iterations() {
    println!("\n=== MEMORY STABILITY (1000 iterations) ===");

    let iterations = 1000;
    let mut success_count = 0;

    let start = Instant::now();

    for i in 0..iterations {
        let log = generate_test_log(20, 5);
        let miner = AlphaMiner::new();
        let model = miner.discover(&log);

        if !model.places().is_empty() {
            success_count += 1;
        }

        if (i + 1) % 100 == 0 {
            println!("  Completed {} iterations", i + 1);
        }
    }

    let elapsed = start.elapsed();

    println!("  Total iterations: {}", success_count);
    println!("  Total time: {:?}", elapsed);
    println!("  Average per iteration: {:.2}ms",
        (elapsed.as_millis() as f64 / success_count as f64));

    assert_eq!(success_count, iterations, "Not all iterations completed successfully");
}
