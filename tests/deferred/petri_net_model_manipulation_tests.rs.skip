//! PetriNet Model Manipulation and Token Game Semantics Integration Tests
//!
//! Tests the deepest untested APIs in pm4py-rust:
//! - PetriNet construction (add_place, add_transition, add_arc)
//! - PetriNet lookup (get_place, get_transition, get_arcs_from/to)
//! - Workflow net topology (set_initial_place, set_final_place, source_places, sink_places)
//! - Transition filtering (visible_transitions, invisible_transitions)
//! - Token game semantics (is_transition_enabled, fire_transition)
//! - State-space exploration (count_reachable_states)
//! - Place/Transition builders (with_initial_marking, with_final_marking, is_invisible)
//!
//! Chicago TDD: NO MOCKS, testing against real constructed Petri nets

use pm4py::discovery::AlphaMiner;
use pm4py::io::CSVReader;
use pm4py::log::{Event, EventLog, Trace};
use pm4py::models::petri_net::{Arc, Place, PetriNet, Transition};
use std::collections::HashMap;
use std::path::Path;

fn load_invoice() -> EventLog {
    let path = format!(
        "{}/canopy/priv/demo_data/invoice_events.csv",
        std::env::var("HOME").unwrap()
    );
    CSVReader::new()
        .with_case_column("case_id")
        .with_activity_column("activity")
        .with_timestamp_column("timestamp")
        .read(Path::new(&path))
        .unwrap_or_else(|_| {
            let mut log = EventLog::new();
            let now = chrono::Utc::now();
            for i in 0..10 {
                let mut trace = Trace::new(format!("case_{}", i));
                trace.add_event(Event::new("register", now).with_resource("clerk"));
                trace.add_event(Event::new("examine", now + chrono::Duration::minutes(10)).with_resource("senior"));
                trace.add_event(Event::new("decide", now + chrono::Duration::hours(1)).with_resource("mgr"));
                log.add_trace(trace);
            }
            log
        })
}

// ============================================================================
// 1. Place and Transition Builders
// ============================================================================

#[test]
fn test_place_with_initial_marking() {
    let place = Place::new("start").with_initial_marking(1);
    assert_eq!(place.initial_marking, 1);
    assert_eq!(place.name, "start");
    assert!(place.final_marking.is_none());
}

#[test]
fn test_place_with_final_marking() {
    let place = Place::new("end").with_initial_marking(0).with_final_marking(1);
    assert_eq!(place.initial_marking, 0);
    assert_eq!(place.final_marking, Some(1));
}

#[test]
fn test_transition_with_label() {
    let t = Transition::new("t1").with_label("register");
    assert_eq!(t.name, "t1");
    assert_eq!(t.label, Some("register".to_string()));
    assert!(!t.is_invisible());
}

#[test]
fn test_transition_invisible_tau() {
    let t = Transition::new("tau");
    assert!(t.label.is_none());
    assert!(t.is_invisible());
}

#[test]
fn test_arc_with_weight() {
    let arc = Arc::new("p1", "t1").with_weight(2);
    assert_eq!(arc.weight, 2);
}

// ============================================================================
// 2. PetriNet Construction
// ============================================================================

#[test]
fn test_petri_net_manual_construction() {
    let mut net = PetriNet::new();
    let p1 = Place::new("source").with_initial_marking(1);
    let t1 = Transition::new("start").with_label("start");
    let p2 = Place::new("sink").with_final_marking(1);

    let p1_id = p1.id.clone();
    let t1_id = t1.id.clone();
    let p2_id = p2.id.clone();

    net.add_place(p1);
    net.add_transition(t1);
    net.add_place(p2);
    net.add_arc(Arc::new(&p1_id, &t1_id));
    net.add_arc(Arc::new(&t1_id, &p2_id));

    assert_eq!(net.places.len(), 2);
    assert_eq!(net.transitions.len(), 1);
    assert_eq!(net.arcs.len(), 2);
}

#[test]
fn test_petri_net_with_parallel_paths() {
    // Build: source -> t1 -> p2 -> t3 -> sink
    //              \-> t2 -> p3 -> t4 -> sink
    let mut net = PetriNet::new();
    let source = Place::new("source").with_initial_marking(1);
    let sink = Place::new("sink").with_final_marking(1);
    let p2 = Place::new("p2");
    let p3 = Place::new("p3");
    let t1 = Transition::new("t1").with_label("path_a");
    let t2 = Transition::new("t2").with_label("path_b");
    let t3 = Transition::new("t3").with_label("join");
    let t4 = Transition::new("t4").with_label("join");

    let source_id = source.id.clone();
    let sink_id = sink.id.clone();
    let p2_id = p2.id.clone();
    let p3_id = p3.id.clone();
    let t1_id = t1.id.clone();
    let t2_id = t2.id.clone();
    let t3_id = t3.id.clone();
    let t4_id = t4.id.clone();

    net.add_place(source);
    net.add_place(p2);
    net.add_place(p3);
    net.add_place(sink);
    net.add_transition(t1);
    net.add_transition(t2);
    net.add_transition(t3);
    net.add_transition(t4);
    net.add_arc(Arc::new(&source_id, &t1_id));
    net.add_arc(Arc::new(&source_id, &t2_id));
    net.add_arc(Arc::new(&t1_id, &p2_id));
    net.add_arc(Arc::new(&t2_id, &p3_id));
    net.add_arc(Arc::new(&p2_id, &t3_id));
    net.add_arc(Arc::new(&p3_id, &t4_id));
    net.add_arc(Arc::new(&t4_id, &sink_id));

    assert_eq!(net.places.len(), 4);
    assert_eq!(net.transitions.len(), 4);
    assert_eq!(net.arcs.len(), 8);
    assert_eq!(net.visible_transitions().len(), 4);
}

#[test]
fn test_petri_net_with_tau_transitions() {
    let mut net = PetriNet::new();
    let p1 = Place::new("p1").with_initial_marking(1);
    let tau = Transition::new("tau"); // invisible
    let p2 = Place::new("p2");
    let vis = Transition::new("vis").with_label("visible");

    let p1_id = p1.id.clone();
    let p2_id = p2.id.clone();
    let tau_id = tau.id.clone();
    let vis_id = vis.id.clone();

    net.add_place(p1);
    net.add_place(p2);
    net.add_transition(tau);
    net.add_transition(vis);
    net.add_arc(Arc::new(&p1_id, &tau_id));
    net.add_arc(Arc::new(&tau_id, &p2_id));
    net.add_arc(Arc::new(&p1_id, &vis_id));
    net.add_arc(Arc::new(&vis_id, &p2_id));

    assert_eq!(net.invisible_transitions().len(), 1);
    assert_eq!(net.visible_transitions().len(), 1);
    assert!(net.invisible_transitions()[0].is_invisible());
}

// ============================================================================
// 3. PetriNet Lookup
// ============================================================================

#[test]
fn test_get_place_and_transition() {
    let mut net = PetriNet::new();
    let p = Place::new("my_place");
    let t = Transition::new("my_trans").with_label("labeled");
    let p_id = p.id.clone();
    let t_id = t.id.clone();

    net.add_place(p);
    net.add_transition(t);

    assert!(net.get_place(&p_id).is_some());
    assert!(net.get_place("nonexistent").is_none());
    assert!(net.get_transition(&t_id).is_some());
    assert!(net.get_transition("nonexistent").is_none());

    assert_eq!(net.get_place(&p_id).unwrap().name, "my_place");
    assert_eq!(net.get_transition(&t_id).unwrap().label, Some("labeled".to_string()));
}

#[test]
fn test_get_arcs_from_and_to() {
    let mut net = PetriNet::new();
    let p1 = Place::new("p1");
    let p2 = Place::new("p2");
    let p3 = Place::new("p3");
    let t1 = Transition::new("t1");

    let p1_id = p1.id.clone();
    let p2_id = p2.id.clone();
    let p3_id = p3.id.clone();
    let t1_id = t1.id.clone();

    net.add_place(p1);
    net.add_place(p2);
    net.add_place(p3);
    net.add_transition(t1);

    net.add_arc(Arc::new(&p1_id, &t1_id));
    net.add_arc(Arc::new(&t1_id, &p2_id));
    net.add_arc(Arc::new(&t1_id, &p3_id));

    let arcs_from_p1 = net.get_arcs_from(&p1_id);
    assert_eq!(arcs_from_p1.len(), 1);
    assert_eq!(arcs_from_p1[0].to, t1_id);

    let arcs_to_p2 = net.get_arcs_to(&p2_id);
    assert_eq!(arcs_to_p2.len(), 1);
    assert_eq!(arcs_to_p2[0].from, t1_id);

    let arcs_to_t1 = net.get_arcs_to(&t1_id);
    assert_eq!(arcs_to_t1.len(), 1);

    let arcs_from_t1 = net.get_arcs_from(&t1_id);
    assert_eq!(arcs_from_t1.len(), 2); // t1 -> p2 and t1 -> p3
}

